        New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = DropWindow })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1), Parent = DropWindow })
        New("UIPadding", {
            PaddingTop = UDim.new(0, 4),
            PaddingBottom = UDim.new(0, 4),
            Parent = DropWindow
        })

        local Dropdo = { Value = Info.Multi and {} or Info.Default, Type = "Dropdown" }
        local MenuActive = false

        function Dropdo:UpdateLabels()
            local label = ""
            if Info.Multi then
                local tabS = {}
                for k, v in pairs(Dropdo.Value) do if v then table.insert(tabS, tostring(k)) end end
                label = #tabS > 0 and table.concat(tabS, ", ") or "none"
            else
                label = Dropdo.Value and tostring(Dropdo.Value) or "none"
            end
            Disp.Text = "  " .. label
        end

        function Dropdo:SyncRenderOptions()
            for _, Chd in pairs(DropWindow:GetChildren()) do
                if Chd:IsA("TextButton") then Chd:Destroy() end
            end
            local total = 8
            for _, TxtMap in ipairs(Info.Values) do
                local Btn = New("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 22),
                    Text = tostring(TxtMap),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextColor3 = "SecondaryColor",
                    TextSize = 11, FontFace = "Font",
                    ZIndex = 51, Parent = DropWindow
                })
                New("UIPadding", { PaddingLeft = UDim.new(0, 10), Parent = Btn })

                local function refresh()
                    local isSelected = Info.Multi and Dropdo.Value[TxtMap] or Dropdo.Value == TxtMap
                    Btn.TextColor3 = isSelected and Library.Scheme.AccentColor or Library.Scheme.SecondaryColor
                end
                refresh()

                Btn.MouseEnter:Connect(function() Btn.BackgroundTransparency = 0.85; Btn.BackgroundColor3 = Library.Scheme.SubColor end)
                Btn.MouseLeave:Connect(function() Btn.BackgroundTransparency = 1 end)

                Btn.MouseButton1Click:Connect(function()
                    if Info.Multi then
                        Dropdo.Value[TxtMap] = not Dropdo.Value[TxtMap]
                    else
                        Dropdo.Value = TxtMap
                        MenuActive = false
                        DropWindow.Visible = false
                        TweenService:Create(Arrow, Library.TweenInfo, { Rotation = 0 }):Play()
                    end
                    refresh()
                    Dropdo:UpdateLabels()
                    Library:SafeCallback(Info.Callback, Dropdo.Value)
                end)
                total = total + 23
            end
            DropWindow.CanvasSize = UDim2.new(0, 0, 0, total)
            DropWindow.Size = UDim2.new(0, Disp.AbsoluteSize.X, 0, math.clamp(total, 0, 160))
        end

        Disp.MouseButton1Click:Connect(function()
            MenuActive = not MenuActive
            if MenuActive then
                DropWindow.Position = UDim2.new(0, Disp.AbsolutePosition.X, 0, Disp.AbsolutePosition.Y + Disp.AbsoluteSize.Y + 4)
                DropWindow.Size = UDim2.new(0, Disp.AbsoluteSize.X, 0, DropWindow.Size.Y.Offset)
            end
            DropWindow.Visible = MenuActive
            TweenService:Create(Arrow, Library.TweenInfo, { Rotation = MenuActive and 180 or 0 }):Play()
        end)

        Dropdo:SyncRenderOptions(); Dropdo:UpdateLabels(); self:Resize()
        table.insert(self.Elements, Dropdo); Library.Options[Idx] = Dropdo
        return Dropdo
    end

