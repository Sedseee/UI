    function Class:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 38), Parent = self.Container })

        New("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(0.6, 0, 0, 14),
            Text = Info.Text:lower(), TextSize = 11,
            TextColor3 = "FontColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace = "Font", Parent = Holder
        })
        local ValLab = New("TextLabel", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, 0, 0, 0),
            Size = UDim2.new(0.4, 0, 0, 14),
            Text = "", TextSize = 11,
            TextColor3 = "AccentColor",
            TextXAlignment = Enum.TextXAlignment.Right,
            FontFace = "Font", Parent = Holder
        })

        local Interact = New("TextButton", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(0, 1),
            Position = UDim2.new(0, 0, 1, 0),
            Size = UDim2.new(1, 0, 0, 16),
            Text = "", Parent = Holder
        })

        local Bar = New("Frame", {
            BackgroundColor3 = "SubColor",
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 0, 0.5, 0),
            Size = UDim2.new(1, 0, 0, 4),
            Parent = Interact
        })
        New("UICorner", { CornerRadius = UDim.new(0, 2), Parent = Bar })
        New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Bar })

        local Fill = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0, 0, 1, 0), Parent = Bar })
        New("UICorner", { CornerRadius = UDim.new(0, 2), Parent = Fill })

        local SliderObj = { Value = Info.Default, Type = "Slider" }

        function SliderObj:UpdateDisplay()
            local pct = math.clamp((SliderObj.Value - Info.Min) / (Info.Max - Info.Min), 0, 1)
            ValLab.Text = tostring(SliderObj.Value) .. Info.Suffix
            TweenService:Create(Fill, Library.TweenInfo, { Size = UDim2.new(pct, 0, 1, 0) }):Play()
        end

        function SliderObj:SetValue(Val)
            Val = math.clamp(Val, Info.Min, Info.Max)
            if Info.Rounding > 0 then
                local m = 10 ^ Info.Rounding
                Val = math.floor(Val * m + 0.5) / m
            else
                Val = math.floor(Val + 0.5)
            end
            SliderObj.Value = Val
            SliderObj:UpdateDisplay()
            Library:SafeCallback(Info.Callback, Val)
        end

        local Dragging
        Interact.InputBegan:Connect(function(Imp)
            if Imp.UserInputType == Enum.UserInputType.MouseButton1 or Imp.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                while Dragging and RunService.RenderStepped:Wait() do
                    local mouseX = UserInputService:GetMouseLocation().X
                    local barX = Interact.AbsolutePosition.X
                    local pct = math.clamp((mouseX - barX) / Interact.AbsoluteSize.X, 0, 1)
                    SliderObj:SetValue(Info.Min + (Info.Max - Info.Min) * pct)
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(Imp)
            if Imp.UserInputType == Enum.UserInputType.MouseButton1 or Imp.UserInputType == Enum.UserInputType.Touch then
                Dragging = false
            end
        end)

        SliderObj:UpdateDisplay(); self:Resize()
        table.insert(self.Elements, SliderObj); Library.Options[Idx] = SliderObj
        return SliderObj
    end

