        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 4),
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Parent = TabStrip
    })

    -- Window controls (right)
    local Controls = New("Frame", {
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.fromOffset(60, 20),
        Parent = Topbar
    })
    New("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Padding = UDim.new(0, 10),
        Parent = Controls
    })

    local function makeCtrl(symbol, order)
        local b = New("TextButton", {
            BackgroundTransparency = 1,
            LayoutOrder = order,
            Size = UDim2.fromOffset(14, 14),
            Text = symbol,
            TextColor3 = "SecondaryColor",
            TextSize = 12,
            FontFace = "Font",
            Parent = Controls
        })
        b.MouseEnter:Connect(function() b.TextColor3 = Library.Scheme.AccentColor end)
        b.MouseLeave:Connect(function() b.TextColor3 = Library.Scheme.SecondaryColor end)
        return b
    end

    local Mbx = makeCtrl("_", 1)
    local CbX = makeCtrl("x", 2)

    CbX.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    -- Content area
    local Content = New("Frame", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 38),
        Size = UDim2.new(1, 0, 1, -38),
        ClipsDescendants = true,
        Parent = Window
    })

    local minimized = false
    local fullSize = Info.Size
    Mbx.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            Content.Visible = false
            Window:TweenSize(UDim2.fromOffset(fullSize.X.Offset, 38), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.18, true)
        else
            Window:TweenSize(fullSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.18, true)
            task.wait(0.15)
            Content.Visible = true
        end
    end)

    local UIStateObj = { ExtTabs = {} }

    function UIStateObj:AddTab(LabelT, IconSource)
        -- Pill-style tab button
        local TabBtn = New("TextButton", {
            BackgroundColor3 = "MainColor",
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 0, 1, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            Text = "",
            Parent = TabStrip
        })
        New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = TabBtn })
        New("UIPadding", {
            PaddingLeft = UDim.new(0, 10),
            PaddingRight = UDim.new(0, 10),
            Parent = TabBtn
        })

        local inner = New("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 0, 1, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            Parent = TabBtn
        })
        New("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 6),
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Parent = inner
        })

        local AcCis = Library:GetCustomIcon(IconSource or "menu")
        local IcoRef = New("ImageLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.fromOffset(13, 13),
            Image = AcCis and AcCis.Url or "",
            ImageRectOffset = AcCis and AcCis.ImageRectOffset or Vector2.zero,
            ImageRectSize = AcCis and AcCis.ImageRectSize or Vector2.zero,
            ImageColor3 = "SecondaryColor",
            LayoutOrder = 1,
            Parent = inner
        })
        local TitleRef = New("TextLabel", {
            BackgroundTransparency = 1,
            AutomaticSize = Enum.AutomaticSize.X,
            Size = UDim2.new(0, 0, 0, 14),
            Text = LabelT:lower(),
            TextSize = 11,
            TextColor3 = "SecondaryColor",
            FontFace = "Font",
            LayoutOrder = 2,
            Parent = inner
        })

        -- Underline indicator for active tab
        local Indicator = New("Frame", {
            BackgroundColor3 = "AccentColor",
            AnchorPoint = Vector2.new(0.5, 1),
            Position = UDim2.new(0.5, 0, 1, 0),
            Size = UDim2.new(0, 0, 0, 2),
            Parent = TabBtn
        })

        local Page = New("ScrollingFrame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            CanvasSize = UDim2.new(),
            ScrollBarThickness = 2,
            Visible = false,
            Parent = Content
        })
        New("UIPadding", {
            PaddingTop = UDim.new(0, 14),
            PaddingBottom = UDim.new(0, 14),
            PaddingLeft = UDim.new(0, 14),
            PaddingRight = UDim.new(0, 14),
            Parent = Page
        })

        local Lx = New("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0.5, -7, 1, 0),
            Parent = Page
        })
        local Rx = New("Frame", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, 0, 0, 0),
            Size = UDim2.new(0.5, -7, 1, 0),
            Parent = Page
        })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 12), Parent = Lx })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 12), Parent = Rx })

        local CurCtxt = { MainPage = Page, ColumnL = Lx, ColumnR = Rx }

        local function deselect()
            IcoRef.ImageColor3 = Library.Scheme.SecondaryColor
            TitleRef.TextColor3 = Library.Scheme.SecondaryColor
            TweenService:Create(Indicator, Library.TweenInfo, { Size = UDim2.new(0, 0, 0, 2) }):Play()
            Page.Visible = false
        end
        local function select()
            IcoRef.ImageColor3 = Library.Scheme.AccentColor
            TitleRef.TextColor3 = Library.Scheme.FontColor
            TweenService:Create(Indicator, Library.TweenInfo, { Size = UDim2.new(1, 0, 0, 2) }):Play()
            Page.Visible = true
        end

        TabBtn.MouseEnter:Connect(function()
            if Library.RefSysTab and Library.RefSysTab.PageInstance == Page then return end
            TitleRef.TextColor3 = Library.Scheme.FontColor
        end)
        TabBtn.MouseLeave:Connect(function()
            if Library.RefSysTab and Library.RefSysTab.PageInstance == Page then return end
            TitleRef.TextColor3 = Library.Scheme.SecondaryColor
        end)

        TabBtn.MouseButton1Click:Connect(function()
            if Library.RefSysTab then
                Library.RefSysTab.Deselect()
            end
            select()
            Library.RefSysTab = { PageInstance = Page, Deselect = deselect }
        end)

        if not Library.RefSysTab then
            select()
            Library.RefSysTab = { PageInstance = Page, Deselect = deselect }
        end

        function CurCtxt:AddGroup(TitleG, AlignmentID)
            local TrzCol = AlignmentID == 2 and Rx or Lx
            local Grpx = New("Frame", {
                BackgroundColor3 = "MainColor",
                Size = UDim2.new(1, 0, 0, 100),
                Parent = TrzCol
            })
            New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Grpx })
            New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Grpx })

            -- Header band
            local Header = New("Frame", {
                BackgroundColor3 = "SubColor",
                Size = UDim2.new(1, 0, 0, 26),
                Parent = Grpx
            })
            New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Header })
            -- Bottom mask so corner is only at top
            New("Frame", {
                BackgroundColor3 = "SubColor",
                AnchorPoint = Vector2.new(0, 1),
                Position = UDim2.new(0, 0, 1, 0),
                Size = UDim2.new(1, 0, 0, 6),
                BorderSizePixel = 0,
                Parent = Header
            })
            New("Frame", {
                BackgroundColor3 = "OutlineColor",
                AnchorPoint = Vector2.new(0, 1),
                Position = UDim2.new(0, 0, 1, 0),
                Size = UDim2.new(1, 0, 0, 1),
                Parent = Header
            })

            -- Accent stripe
            New("Frame", {
                BackgroundColor3 = "AccentColor",
                Size = UDim2.new(0, 3, 1, 0),
                Parent = Header
            })
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 12, 0, 0),
                Size = UDim2.new(1, -24, 1, 0),
                Text = "// " .. TitleG:lower(),
                TextSize = 11,
                TextColor3 = "FontColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                FontFace = "Font",
                Parent = Header
            })

            local PContainer = New("Frame", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 0, 0, 26),
                Size = UDim2.new(1, 0, 1, -26),
                Parent = Grpx
            })
            New("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 8),
                Parent = PContainer
            })
            New("UIPadding", {
                PaddingTop = UDim.new(0, 10),
                PaddingBottom = UDim.new(0, 12),
                PaddingLeft = UDim.new(0, 12),
                PaddingRight = UDim.new(0, 12),
                Parent = PContainer
            })

            local Master = { Holder = Grpx, Container = PContainer, Elements = {}, TabObj = CurCtxt }
            setmetatable(Master, GBLayout)
            Master:Resize()
            return Master
        end

        function CurCtxt:AddLeftGroupbox(name)  return CurCtxt:AddGroup(name, 1) end
        function CurCtxt:AddRightGroupbox(name) return CurCtxt:AddGroup(name, 2) end

        return CurCtxt
    end

    UserInputService.InputBegan:Connect(function(Imp)
        if Imp.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end)
    return UIStateObj
end

getgenv().Library = Library
return Library
 
