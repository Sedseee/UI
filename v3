--[[ 
    SYNQ UI LIBRARY - V3 (BULLETPROOF EXECUTOR PATCH)
    - Fixed AutomaticSize collapsing (Manual ContentSize Tracking)
    - Fixed Font.new crashes (Using Safe Native Enums)
    - Scaled down to match reference size perfectly
    - Restored all modules (Settings, Mobile, Lists, Status, etc.)
]]

local uis = game:GetService("UserInputService") 
local tween_service = game:GetService("TweenService")
local core_gui = game:GetService("CoreGui")

local function get_ui_parent()
    local success, parent = pcall(function() return gethui and gethui() end)
    if success and parent then return parent end
    return core_gui
end

local library = {}
library.__index = library

local connections = {}
local function track_connection(conn)
    if conn then table.insert(connections, conn) end
    return conn
end

function library:Unload()
    for _, conn in ipairs(connections) do if conn then conn:Disconnect() end end
    table.clear(connections)
    local parent = get_ui_parent()
    if parent:FindFirstChild("SynqUI") then parent.SynqUI:Destroy() end
    if parent:FindFirstChild("SynqNotifs") then parent.SynqNotifs:Destroy() end
end

local function global_cleanup()
    local parent = get_ui_parent()
    if parent:FindFirstChild("SynqUI") then parent.SynqUI:Destroy() end
    if parent:FindFirstChild("SynqNotifs") then parent.SynqNotifs:Destroy() end
end
global_cleanup()

local dim2 = UDim2.new
local dim = UDim.new 
local rgb = Color3.fromRGB
local ui_parent = get_ui_parent()

-- Brightened Theme to ensure sections aren't completely pitch black
local Theme = {
    MainBG = rgb(15, 15, 15),
    SidebarBG = rgb(20, 20, 20),
    SectionBG = rgb(24, 24, 24),
    ElementBG = rgb(32, 32, 32),
    HoverBG = rgb(42, 42, 42),
    Accent = rgb(255, 65, 50), -- Synq Red/Orange
    Text = rgb(240, 240, 240),
    MutedText = rgb(140, 140, 140),
    Outline = rgb(45, 45, 45)
}

function library:tween(obj, props, time) 
    local t = tween_service:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

function library:create(class, props)
    local ins = Instance.new(class)
    for k, v in pairs(props) do ins[k] = v end
    return ins
end

function library:draggify(frame, drag_area)
    local dragging, startPos, startInput
    (drag_area or frame).InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; startInput = input.Position; startPos = frame.Position
        end
    end)
    track_connection(uis.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - startInput
            frame.Position = dim2(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end))
    track_connection(uis.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end))
end

-- Fallback Icons (Uses a circle icon if GitHub raw fails)
local function get_icon(iconName, color)
    local img = Instance.new("ImageLabel")
    img.BackgroundTransparency = 1
    img.Image = "rbxassetid://13112879555" 
    img.ImageColor3 = color or Theme.MutedText
    
    task.spawn(function()
        pcall(function()
            local Icons = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/Icons/main/Main-v2.lua"))()
            if Icons then 
                Icons.SetIconsType("lucide")
                local iconStr = iconName:gsub("^lucide:", "")
                local ok, iconObj = pcall(function() return Icons.Image({ Icon = iconStr }) end)
                if ok and iconObj and iconObj.IconFrame then
                    img.Image = iconObj.IconFrame:FindFirstChildOfClass("ImageLabel").Image
                end
            end
        end)
    end)
    
    return img
end

local function color_icon(iconInstance, color)
    if not iconInstance then return end
    library:tween(iconInstance, {ImageColor3 = color}, 0.15)
end

-- Bulletproof Content Size Tracker (Replaces AutomaticSize)
local function track_height(layout, frame, padding)
    local function update() frame.Size = dim2(frame.Size.X.Scale, frame.Size.X.Offset, 0, layout.AbsoluteContentSize.Y + (padding or 0)) end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
    update()
end

