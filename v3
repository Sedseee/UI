    local tab_layout = library:create("UIListLayout", {Parent = tab_container, Padding = dim(0, 2), HorizontalAlignment = Enum.HorizontalAlignment.Center, SortOrder = Enum.SortOrder.LayoutOrder})
    tab_layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() tab_container.CanvasSize = dim2(0, 0, 0, tab_layout.AbsoluteContentSize.Y + 20) end)

    local page_holder = library:create("Frame", { Parent = main, Position = dim2(0, 135, 0, 40), Size = dim2(1, -145, 1, -45), BackgroundTransparency = 1 })

