            library:create("UIPadding", {Parent = dropWindow, PaddingTop = dim(0, 6), PaddingBottom = dim(0, 6)})

            local menuActive, dropConn = false, nil
            local function updateDropPos() dropWindow.Position = dim2(0, btn.AbsolutePosition.X, 0, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 4) end
            local function closeMenu()
                menuActive = false; dropWindow.Visible = false
                if dropConn then dropConn:Disconnect(); dropConn = nil end
                library:tween(arrow, {Rotation = 0}, 0.15)
            end

            local function syncOptions(itemList)
                for _, c in pairs(dropWindow:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                local total = 12
                for _, val in ipairs(itemList) do
                    local iBtn = library:create("TextButton", {Parent = dropWindow, BackgroundTransparency = 1, Size = dim2(1, 0, 0, 24), Text = tostring(val), TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Theme.MutedText, TextSize = 11, FontFace = library.font, ZIndex = 51})
