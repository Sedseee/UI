                    refresh()

                    iBtn.MouseEnter:Connect(function() iBtn.BackgroundTransparency = 0.8; iBtn.BackgroundColor3 = Theme.ElementBG end)
                    iBtn.MouseLeave:Connect(function() iBtn.BackgroundTransparency = 1 end)
                    iBtn.MouseButton1Click:Connect(function()
                        if isMulti then
                            local idx = table.find(selected, val)
                            if idx then table.remove(selected, idx) else table.insert(selected, val) end
                        else
                            selected = val; closeMenu()
                        end
                        for _, c in pairs(dropWindow:GetChildren()) do if c:IsA("TextButton") then
                            local s = isMulti and table.find(selected, c.Text) or (selected == c.Text)
                            c.TextColor3 = s and Theme.Accent or Theme.MutedText
                        end end
                        lbl.Text = string.lower(get_val_str())
                        if p.Callback then p.Callback(selected) end
                    end)
                    total = total + 26
                end
                dropWindow.CanvasSize = dim2(0, 0, 0, total)
                dropWindow.Size = dim2(0, btn.AbsoluteSize.X, 0, math.clamp(total, 0, 160))
            end

            syncOptions(p.items or {})

            btn.MouseButton1Click:Connect(function()
                menuActive = not menuActive
                if menuActive then
                    updateDropPos(); dropWindow.Visible = true; library:tween(arrow, {Rotation = 180}, 0.15)
                    if dropConn then dropConn:Disconnect() end
                    dropConn = run_service.RenderStepped:Connect(updateDropPos)
                else closeMenu() end
            end)

            track_connection(uis.InputBegan:Connect(function(inp)
                if not menuActive then return end
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    local mx, my = inp.Position.X, inp.Position.Y
                    local dp, ds, bp, bs = dropWindow.AbsolutePosition, dropWindow.AbsoluteSize, btn.AbsolutePosition, btn.AbsoluteSize
                    if not (mx >= dp.X and mx <= dp.X + ds.X and my >= dp.Y and my <= dp.Y + ds.Y) and not (mx >= bp.X and mx <= bp.X + bs.X and my >= bp.Y and my <= bp.Y + bs.Y) then
                        closeMenu()
                    end
                end
            end))

            local api = {
                set_items = function(self, new_items) syncOptions(new_items) end,
                set_value = function(self, val) selected = val; lbl.Text = string.lower(get_val_str()); if p.Callback then p.Callback(selected) end end,
                set = function(self, val) self:set_value(val) end,
                get_value = function(self) return selected end
