                        pickerDot.Position = dim2(0.5 + (offset.X / wheel.AbsoluteSize.X), 0, 0.5 + (offset.Y / wheel.AbsoluteSize.Y), 0)
                        local a = math.atan2(-offset.Y, offset.X); h = (a / (math.pi * 2)) + 0.5; h = h % 1; s = offset.Magnitude / rad; update_color()
