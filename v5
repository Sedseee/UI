function Library:MakeDraggable(UI, DragFrame)
    local StartPos, FramePos, Dragging, Changed
    DragFrame.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            StartPos = Input.Position
            FramePos = UI.Position
            Dragging = true
            Changed = Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then Dragging = false; if Changed then Changed:Disconnect() end end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
            local Delta = Input.Position - StartPos
            UI.Position = UDim2.new(FramePos.X.Scale, FramePos.X.Offset + Delta.X, FramePos.Y.Scale, FramePos.Y.Offset + Delta.Y)
        end
    end)
end

--// Addons & Base Classes
local BaseAddons = {}
do
    local Funcs = {}
    
    function Funcs:AddToggle(Idx, Info)
        Info = Library:Validate(Info, Templates.Toggle)
        local Groupbox = self
        local Height = Info.Description ~= "" and 40 or 26
        local Toggle = { Value = Info.Default, Type = "Toggle", Callback = Info.Callback }

        local Holder = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, Height), Text = "", Parent = Groupbox.Container })
        local Label = New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -45, 0, 16), Text = Info.Text, TextSize = 13, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        
        if Info.Description ~= "" then
            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 16), Size = UDim2.new(1, -45, 0, 14), Text = Info.Description, TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        end

        local Switch = New("Frame", { BackgroundColor3 = "MainColor", AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.fromOffset(34, 18), Parent = Holder })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Switch })
        local SwitchStroke = New("UIStroke", { Color = "OutlineColor", Parent = Switch })
        
        local Knob = New("Frame", { BackgroundColor3 = "SecondaryColor", AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 2, 0.5, 0), Size = UDim2.fromOffset(14, 14), Parent = Switch })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Knob })

        function Toggle:Display()
            local IsOn = Toggle.Value
            TweenService:Create(Switch, Library.TweenInfo, { BackgroundColor3 = IsOn and Library.Scheme.AccentColor or Library.Scheme.MainColor }):Play()
            TweenService:Create(SwitchStroke, Library.TweenInfo, { Color = IsOn and Library.Scheme.AccentColor or Library.Scheme.OutlineColor }):Play()
            TweenService:Create(Knob, Library.TweenInfo, { Position = IsOn and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0), BackgroundColor3 = IsOn and Color3.new(1,1,1) or Library.Scheme.SecondaryColor }):Play()
        end

        function Toggle:SetValue(Val)
            Toggle.Value = Val
            Toggle:Display()
            Library:SafeCallback(Toggle.Callback, Toggle.Value)
        end

        Holder.MouseButton1Click:Connect(function() Toggle:SetValue(not Toggle.Value) end)
        Toggle:Display()
        Groupbox:Resize()
        table.insert(Groupbox.Elements, Toggle); Library.Options[Idx] = Toggle
        return Toggle
    end

    function Funcs:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Groupbox = self
        local Slider = { Value = Info.Default, Min = Info.Min, Max = Info.Max, Type = "Slider", Callback = Info.Callback }

        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 36), Parent = Groupbox.Container })
        local Label = New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(0.5, 0, 0, 16), Text = Info.Text, TextSize = 13, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        local ValLabel = New("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0.5, 0, 0, 16), Text = "", TextSize = 13, TextColor3 = "AccentColor", TextXAlignment = Enum.TextXAlignment.Right, FontFace = "Font", Parent = Holder })
        
        local BarArea = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(0,1), Position = UDim2.new(1,0,1,0), Size = UDim2.new(1, 0, 0, 14), Text = "", Parent = Holder })
        local Bar = New("Frame", { BackgroundColor3 = "MainColor", AnchorPoint = Vector2.new(0,0.5), Position = UDim2.new(0,0,0.5,0), Size = UDim2.new(1,0,0,4), Parent = BarArea })
        New("UICorner", { CornerRadius = UDim.new(1,0), Parent = Bar })
        New("UIStroke", { Color = "OutlineColor", Parent = Bar })

        local Fill = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0,0,1,0), Parent = Bar })
        New("UICorner", { CornerRadius = UDim.new(1,0), Parent = Fill })
        local Knob = New("Frame", { BackgroundColor3 = "AccentColor", AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(1,0,0.5,0), Size = UDim2.fromOffset(10,10), Parent = Fill })
        New("UICorner", { CornerRadius = UDim.new(1,0), Parent = Knob })

        function Slider:Display()
            local Pct = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
            ValLabel.Text = tostring(Slider.Value) .. Info.Suffix
            Fill.Size = UDim2.new(math.clamp(Pct, 0, 1), 0, 1, 0)
        end

        function Slider:SetValue(Val)
            Val = math.clamp(Val, Slider.Min, Slider.Max)
            Val = Info.Rounding > 0 and (math.floor(Val * (10^Info.Rounding) + 0.5) / (10^Info.Rounding)) or math.floor(Val + 0.5)
            if Slider.Value ~= Val then
                Slider.Value = Val
                Slider:Display()
                Library:SafeCallback(Slider.Callback, Slider.Value)
            end
        end

        local Dragging = false
        BarArea.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                while Dragging and RunService.RenderStepped:Wait() do
                    local Pct = math.clamp((Mouse.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                    Slider:SetValue(Slider.Min + ((Slider.Max - Slider.Min) * Pct))
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then Dragging = false end
        end)

        Slider:Display(); Groupbox:Resize()
        table.insert(Groupbox.Elements, Slider); Library.Options[Idx] = Slider
        return Slider
    end

    function Funcs:AddDropdown(Idx, Info)
        Info = Library:Validate(Info, Templates.Dropdown)
        local Groupbox = self
        local Height = Info.Description ~= "" and 54 or 40
        local Dropdown = { Value = Info.Multi and {} or Info.Default, Values = Info.Values, Type = "Dropdown", Callback = Info.Callback }

        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, Height), Parent = Groupbox.Container })
        New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), Text = Info.Text, TextSize = 13, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        if Info.Description ~= "" then
            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 14), Size = UDim2.new(1, 0, 0, 12), Text = Info.Description, TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        end

        local Disp = New("TextButton", { BackgroundColor3 = "BackgroundColor", AnchorPoint = Vector2.new(0,1), Position = UDim2.new(1,0,1,0), Size = UDim2.new(1, 0, 0, 24), Text = "...", TextSize = 12, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        New("UIPadding", { PaddingLeft = UDim.new(0, 8), Parent = Disp })
        New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Disp })
        New("UIStroke", { Color = "OutlineColor", Parent = Disp })
        
        function Dropdown:Display()
            local str = ""
            if Info.Multi then
                local sel = {}
                for k,v in pairs(Dropdown.Value) do if v then table.insert(sel, k) end end
                str = #sel > 0 and table.concat(sel, ", ") or "None"
            else
                str = Dropdown.Value or "None"
            end
            Disp.Text = str
        end

        Dropdown:Display(); Groupbox:Resize()
        table.insert(Groupbox.Elements, Dropdown); Library.Options[Idx] = Dropdown
        return Dropdown
    end

    function Funcs:AddDivider(Text)
        local Groupbox = self
        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 24), Parent = Groupbox.Container })
        New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = (Text or ""):upper(), TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        Groupbox:Resize()
        return { Holder = Holder, Type = "Divider" }
    end

    BaseAddons.__index = Funcs
end

local BaseGroupbox = {}
do
    local Funcs = setmetatable({}, BaseAddons)
    function Funcs:Resize()
        local height = 0
        for _, child in ipairs(self.Container:GetChildren()) do
            if child:IsA("GuiObject") and child.Visible then height = height + child.AbsoluteSize.Y + 6 end
        end
        self.Holder.Size = UDim2.new(1, 0, 0, height + 36)
    end
    BaseGroupbox.__index = Funcs
end

function Library:CreateWindow(Info)
    Info = Library:Validate(Info, Templates.Window)
    Library.Scheme.Font = Info.Font

    local MainFrame = New("Frame", { BackgroundColor3 = "BackgroundColor", Position = Info.Position, Size = Info.Size, Active = true, ClipsDescendants = true, Parent = ScreenGui })
    New("UICorner", { CornerRadius = UDim.new(0, Library.CornerRadius), Parent = MainFrame })
    New("UIStroke", { Color = "OutlineColor", Parent = MainFrame })

    local DragArea = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 40), Text = "", Parent = MainFrame })
    Library:MakeDraggable(MainFrame, DragArea)

    local Sidebar = New("Frame", { BackgroundColor3 = "BackgroundColor", Size = UDim2.new(0, 150, 1, 0), Parent = MainFrame })
    New("Frame", { BackgroundColor3 = "OutlineColor", Position = UDim2.new(1, -1, 0, 0), Size = UDim2.new(0, 1, 1, 0), Parent = Sidebar })
    
    New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(20, 20), Size = UDim2.new(1, -20, 0, 30), Text = Info.Title, TextSize = 16, TextColor3 = "AccentColor", FontFace = "Font", TextXAlignment = Enum.TextXAlignment.Left, Parent = Sidebar })
    
    local TabContainer = New("ScrollingFrame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 65), Size = UDim2.new(1, 0, 1, -65), ScrollBarThickness = 0, CanvasSize = UDim2.new(0,0,0,0), Parent = Sidebar })
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 0), Parent = TabContainer })
    
    local ContentContainer = New("Frame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(150, 0), Size = UDim2.new(1, -150, 1, 0), Parent = MainFrame })
    local CloseBtn = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, -15, 0, 15), Size = UDim2.fromOffset(14, 14), Text = "X", TextColor3 = "SecondaryColor", TextSize = 14, FontFace = "Font", Parent = MainFrame })
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
    local MinBtn = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, -40, 0, 15), Size = UDim2.fromOffset(14, 14), Text = "-", TextColor3 = "SecondaryColor", TextSize = 18, FontFace = "Font", Parent = MainFrame })

    local Window = {}
    
    function Window:AddTab(Name, IconName)
        local TabBtn = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 55), Text = "", Parent = TabContainer })
        local Indicator = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0, 2, 1, -25), AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.5, 0), Visible = false, Parent = TabBtn })
        
        local ContentWrap = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Parent = TabBtn })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5), HorizontalAlignment = Enum.HorizontalAlignment.Center, VerticalAlignment = Enum.VerticalAlignment.Center, Parent = ContentWrap })
        
        local Icon = Library:GetCustomIcon(IconName or "layout")
        local TabIcon = New("ImageLabel", { BackgroundTransparency = 1, Size = UDim2.fromOffset(18, 18), Image = Icon and Icon.Url or "", ImageRectOffset = Icon and Icon.ImageRectOffset or Vector2.zero, ImageRectSize = Icon and Icon.ImageRectSize or Vector2.zero, ImageColor3 = "SecondaryColor", Parent = ContentWrap })
        local TabLabel = New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 12), Text = Name:lower(), TextSize = 11, TextColor3 = "SecondaryColor", FontFace = "Font", Parent = ContentWrap })
        
        local TabPage = New("ScrollingFrame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), CanvasSize = UDim2.new(0,0,0,0), ScrollBarThickness = 0, Visible = false, Parent = ContentContainer })
        New("UIPadding", { PaddingTop = UDim.new(0, 25), PaddingBottom = UDim.new(0, 25), PaddingLeft = UDim.new(0, 25), PaddingRight = UDim.new(0, 25), Parent = TabPage })
        
        local LeftCol = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0.5, -10, 1, 0), Parent = TabPage })
        local RightCol = New("Frame", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0.5, -10, 1, 0), Parent = TabPage })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 15), Parent = LeftCol })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 15), Parent = RightCol })
        
        local TabData = { Elements = {}, Groupboxes = {} }
        
        function TabData:Show()
            if Library.ActiveTab then Library.ActiveTab:Hide() end
            Indicator.Visible = true
            TweenService:Create(TabIcon, Library.TweenInfo, { ImageColor3 = Library.Scheme.AccentColor }):Play()
            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.FontColor }):Play()
            TabPage.Visible = true
            Library.ActiveTab = TabData
        end
        
        function TabData:Hide()
            Indicator.Visible = false
            TweenService:Create(TabIcon, Library.TweenInfo, { ImageColor3 = Library.Scheme.SecondaryColor }):Play()
            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.SecondaryColor }):Play()
            TabPage.Visible = false
        end
        
        TabBtn.MouseButton1Click:Connect(function() TabData:Show() end)
        if not Library.ActiveTab then TabData:Show() end
        
        function TabData:AddGroupbox(Info)
            local ParentCol = (Info.Side or 1) == 1 and LeftCol or RightCol
            local GbHolder = New("Frame", { BackgroundColor3 = "MainColor", Size = UDim2.new(1, 0, 0, 100), Parent = ParentCol })
            New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = GbHolder })
            New("UIStroke", { Color = "OutlineColor", Parent = GbHolder })
            
            local TopLabel = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 32), Parent = GbHolder })
            New("Frame", { BackgroundColor3 = "AccentColor", Position = UDim2.fromOffset(12, 14), Size = UDim2.fromOffset(5, 5), Parent = TopLabel })
            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(24, 0), Size = UDim2.new(1, -24, 1, 0), Text = Info.Name:lower(), TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = TopLabel })
            New("Frame", { BackgroundColor3 = "OutlineColor", Position = UDim2.new(0, 12, 1, -1), Size = UDim2.new(1, -24, 0, 1), Parent = TopLabel })
            
            local GbContainer = New("Frame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 32), Size = UDim2.new(1, 0, 1, -32), Parent = GbHolder })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = GbContainer })
            New("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 14), Parent = GbContainer })
            
            local Groupbox = { Holder = GbHolder, Container = GbContainer, Elements = {}, Tab = TabData }
            setmetatable(Groupbox, BaseGroupbox)
            Groupbox:Resize()
            return Groupbox
        end
        
        function TabData:AddLeftGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 1 }) end
        function TabData:AddRightGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 2 }) end
        return TabData
    end

    UserInputService.InputBegan:Connect(function(Input)
        if Input.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            Library.Toggled = not Library.Toggled
            MainFrame.Visible = Library.Toggled
        end
    end)
    return Window
end

