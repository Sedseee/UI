    -- ─── Toggle ───────────────────────────────
    function Class:AddToggle(Idx, Info)
        Info = Library:Validate(Info, Templates.Toggle)
        local hasDesc = Info.Description and Info.Description ~= ""
        local Height  = hasDesc and 44 or 28

        local Holder = New("TextButton", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, Height),
            Text = "",
            Parent = self.Container,
        })

        -- iOS-style pill toggle (right side)
        local Track = New("Frame", {
            BackgroundColor3 = "SubColor",
            AnchorPoint      = Vector2.new(1, hasDesc and 0 or 0.5),
            Position         = hasDesc and UDim2.new(1, 0, 0, 4) or UDim2.new(1, 0, 0.5, 0),
            Size             = UDim2.fromOffset(34, 18),
            Parent           = Holder,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })
        local TrackStroke = New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Track })

        local Thumb = New("Frame", {
            BackgroundColor3 = "DimColor",
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(0, 2, 0.5, 0),
            Size             = UDim2.fromOffset(14, 14),
            Parent           = Track,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Thumb })

        New("TextLabel", {
            BackgroundTransparency = 1,
            Position       = UDim2.new(0, 0, 0, 0),
            Size           = UDim2.new(1, -44, 0, hasDesc and 16 or Height),
            Text           = Info.Text:lower(),
            TextSize       = 12,
            TextColor3     = "FontColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace       = "Font",
            Parent         = Holder,
        })

        if hasDesc then
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 0, 0, 18),
                Size           = UDim2.new(1, -44, 0, 18),
                Text           = Info.Description:lower(),
                TextSize       = 10,
                TextColor3     = "SecondaryColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped    = true,
                FontFace       = "Font",
                Parent         = Holder,
            })
        end

        local ToggleObj = { Value = Info.Default, Type = "Toggle", Callback = Info.Callback }

        function ToggleObj:UpdateDisplay()
            local on     = ToggleObj.Value
            local accent = Library.Scheme.AccentColor
            local darkBg = Color3.fromRGB(
                math.floor(accent.R * 255 * 0.18),
                math.floor(accent.G * 255 * 0.18),
                math.floor(accent.B * 255 * 0.18)
            )
            TweenService:Create(Thumb, Library.TweenInfo, {
                Position        = on and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                BackgroundColor3 = on and accent or Library.Scheme.DimColor,
            }):Play()
            TweenService:Create(Track, Library.TweenInfo, {
                BackgroundColor3 = on and darkBg or Library.Scheme.SubColor,
            }):Play()
            TweenService:Create(TrackStroke, Library.TweenInfo, {
                Color = on and accent or Library.Scheme.OutlineColor,
            }):Play()
        end

        function ToggleObj:SetValue(Val)
            ToggleObj.Value = Val
            ToggleObj:UpdateDisplay()
            Library:SafeCallback(ToggleObj.Callback, Val)
        end

        Holder.MouseButton1Click:Connect(function() ToggleObj:SetValue(not ToggleObj.Value) end)
        ToggleObj:UpdateDisplay()
        self:Resize()
        table.insert(self.Elements, ToggleObj)
        Library.Options[Idx] = ToggleObj
        return ToggleObj
    end

    -- ─── Slider ───────────────────────────────
    function Class:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Holder = New("Frame", {
            BackgroundTransparency = 1,
            Size   = UDim2.new(1, 0, 0, 42),
            Parent = self.Container,
        })

        local Header = New("Frame", {
            BackgroundTransparency = 1,
            Size   = UDim2.new(1, 0, 0, 16),
            Parent = Holder,
        })
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size           = UDim2.new(0.6, 0, 1, 0),
            Text           = Info.Text:lower(),
            TextSize       = 11,
            TextColor3     = "FontColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace       = "Font",
            Parent         = Header,
        })
        local ValLab = New("TextLabel", {
            BackgroundTransparency = 1,
            AnchorPoint    = Vector2.new(1, 0),
            Position       = UDim2.new(1, 0, 0, 0),
            Size           = UDim2.new(0.4, 0, 1, 0),
            Text           = "",
            TextSize       = 11,
            TextColor3     = "AccentColor",
            TextXAlignment = Enum.TextXAlignment.Right,
            FontFace       = "Font",
            Parent         = Header,
        })

        local Interact = New("TextButton", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(0, 1),
            Position    = UDim2.new(0, 0, 1, 0),
            Size        = UDim2.new(1, 0, 0, 20),
            Text        = "",
            Parent      = Holder,
        })

        local Bar = New("Frame", {
            BackgroundColor3 = "SubColor",
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(0, 0, 0.5, 0),
            Size             = UDim2.new(1, 0, 0, 5),
            Parent           = Interact,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Bar })

        local Fill = New("Frame", {
            BackgroundColor3 = "AccentColor",
            Size             = UDim2.new(0, 0, 1, 0),
            Parent           = Bar,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })

        -- Thumb dot
        local Thumb = New("Frame", {
            BackgroundColor3 = "FontColor",
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0, 0, 0.5, 0),
            Size             = UDim2.fromOffset(11, 11),
            ZIndex           = 3,
            Parent           = Bar,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Thumb })
        New("UIStroke", { Color = "AccentColor", Thickness = 2, Parent = Thumb })

        local SliderObj = { Value = Info.Default, Type = "Slider" }

        function SliderObj:UpdateDisplay()
            local pct = math.clamp((SliderObj.Value - Info.Min) / (Info.Max - Info.Min), 0, 1)
            ValLab.Text = tostring(SliderObj.Value) .. Info.Suffix
            TweenService:Create(Fill, Library.TweenInfo, { Size = UDim2.new(pct, 0, 1, 0) }):Play()
            TweenService:Create(Thumb, Library.TweenInfo, { Position = UDim2.new(pct, 0, 0.5, 0) }):Play()
        end

        function SliderObj:SetValue(Val)
            Val = math.clamp(Val, Info.Min, Info.Max)
            if Info.Rounding > 0 then
                local m = 10 ^ Info.Rounding
                Val = math.floor(Val * m + 0.5) / m
            else
                Val = math.floor(Val + 0.5)
            end
            SliderObj.Value = Val
            SliderObj:UpdateDisplay()
            Library:SafeCallback(Info.Callback, Val)
        end

        local Dragging = false
        Interact.InputBegan:Connect(function(Imp)
            if Imp.UserInputType == Enum.UserInputType.MouseButton1
                or Imp.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                while Dragging and RunService.RenderStepped:Wait() do
                    local mouseX = UserInputService:GetMouseLocation().X
                    local barX   = Interact.AbsolutePosition.X
                    local pct    = math.clamp((mouseX - barX) / Interact.AbsoluteSize.X, 0, 1)
                    SliderObj:SetValue(Info.Min + (Info.Max - Info.Min) * pct)
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(Imp)
            if Imp.UserInputType == Enum.UserInputType.MouseButton1
                or Imp.UserInputType == Enum.UserInputType.Touch then
                Dragging = false
            end
        end)

        SliderObj:UpdateDisplay()
        self:Resize()
        table.insert(self.Elements, SliderObj)
        Library.Options[Idx] = SliderObj
        return SliderObj
    end

