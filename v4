        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Knob })
        
        function Slider:Display()
            ValueLabel.Text = tostring(Slider.Value) .. (Info.Suffix or "")
            local Pct = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
            Fill.Size = UDim2.new(math.clamp(Pct, 0, 1), 0, 1, 0)
        end
        
        function Slider:SetValue(Val)
            Val = math.clamp(Val, Slider.Min, Slider.Max)
            if Info.Rounding > 0 then
                local mult = 10 ^ Info.Rounding
                Val = math.floor(Val * mult + 0.5) / mult
            else
                Val = math.floor(Val + 0.5)
            end
            Slider.Value = Val
            Slider:Display()
            Library:SafeCallback(Info.Callback, Slider.Value)
        end
        
        local Dragging = false
        BarArea.InputBegan:Connect(function(Input)
            if IsClickInput(Input) then
                Dragging = true
                while Dragging and RunService.RenderStepped:Wait() do
                    local Pct = math.clamp((Mouse.X - BarArea.AbsolutePosition.X) / BarArea.AbsoluteSize.X, 0, 1)
                    Slider:SetValue(Slider.Min + ((Slider.Max - Slider.Min) * Pct))
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = false
            end
        end)
        
        Slider:Display()
        Groupbox:Resize()
        table.insert(Groupbox.Elements, Slider)
        Options[Idx] = Slider
        return Slider
    end

