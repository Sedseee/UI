            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.FontColor }):Play()
            TabPage.Visible = true
            Library.ActiveTab = TabData
        end
        
        function TabData:Hide()
            Indicator.Visible = false
            TweenService:Create(TabIcon, Library.TweenInfo, { ImageColor3 = Library.Scheme.SecondaryColor }):Play()
            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.SecondaryColor }):Play()
            TabPage.Visible = false
        end
        
        TabBtn.MouseButton1Click:Connect(function() TabData:Show() end)
        if not Library.ActiveTab then TabData:Show() end
        
        function TabData:AddGroupbox(Info)
            local Side = Info.Side or 1
            local ParentCol = Side == 1 and LeftCol or RightCol
            
            local GbHolder = New("Frame", {
                BackgroundColor3 = "MainColor", Size = UDim2.new(1, 0, 0, 100), Parent = ParentCol
            })
            New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = GbHolder })
            New("UIStroke", { Color = "OutlineColor", Parent = GbHolder })
            
            local TopLabelContainer = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 30), Parent = GbHolder })
            
            local Square = New("Frame", {
                BackgroundColor3 = "AccentColor", Position = UDim2.fromOffset(12, 12), Size = UDim2.fromOffset(6, 6), Parent = TopLabelContainer
            })
            
            New("TextLabel", {
                BackgroundTransparency = 1, Position = UDim2.fromOffset(26, 0), Size = UDim2.new(1, -26, 1, 0),
                Text = Info.Name:lower(), TextSize = 12, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = TopLabelContainer
            })
            
            local GbLine = New("Frame", {
                BackgroundColor3 = "OutlineColor", Position = UDim2.new(0, 10, 1, -1), Size = UDim2.new(1, -20, 0, 1), Parent = TopLabelContainer
            })
            
            local GbContainer = New("Frame", {
                BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 30), Size = UDim2.new(1, 0, 1, -30), Parent = GbHolder
            })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = GbContainer })
            New("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), Parent = GbContainer })
            
            local Groupbox = {
                Holder = GbHolder,
                Container = GbContainer,
                Elements = {},
                Tab = TabData,
            }
            setmetatable(Groupbox, BaseGroupbox)
            Groupbox:Resize()
            
            return Groupbox
        end
        
        function TabData:AddLeftGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 1 }) end
        function TabData:AddRightGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 2 }) end
        
        return TabData
    end

    UserInputService.InputBegan:Connect(function(Input)
        if Input.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            Library.Toggled = not Library.Toggled
            MainFrame.Visible = Library.Toggled
        end
    end)

    return Window
end

getgenv().Library = Library
return Library
