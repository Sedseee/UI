--// Icon Loader \\--
local FetchIcons, Icons = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/deividcomsono/lucide-roblox-direct/refs/heads/main/source.lua"))()
end)

function Library:GetIcon(IconName: string)
    if not FetchIcons then return nil end
    IconName = IconName:gsub("^lucide:", "")
    local Success, Icon = pcall(Icons.GetAsset, IconName)
    if not Success then return nil end
    return { Url = Icon.Url, ImageRectOffset = Icon.ImageRectOffset, ImageRectSize = Icon.ImageRectSize }
end

--// Utilities \\--
function Library:Validate(Table, Template)
    if typeof(Table) ~= "table" then return Template end
    for k, v in pairs(Template) do
        if Table[k] == nil then Table[k] = v end
    end
    return Table
end

function Library:GiveSignal(Connection)
    table.insert(Library.Signals, Connection)
    return Connection
end

local function New(ClassName, Properties)
    local Inst = Instance.new(ClassName)
    for k, v in pairs(Properties) do
        if k ~= "Parent" then Inst[k] = v end
    end
    if Properties.Parent then Inst.Parent = Properties.Parent end
    return Inst
end

local function CreateTitleAndDesc(Parent, Title, Desc)
    local Holder = New("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Parent = Parent
    })
    local Layout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 2),
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Parent = Holder
    })
    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 14),
        Text = Title,
        TextColor3 = Library.Scheme.Text,
        TextSize = 12,
        FontFace = Library.Scheme.Font,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Holder
    })
    if Desc then
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 12),
            Text = Desc,
            TextColor3 = Library.Scheme.Muted,
            TextSize = 10,
            FontFace = Library.Scheme.Font,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Holder
        })
    end
    return Holder
end

function Library:MakeDraggable(UI, DragFrame)
    local Dragging, StartPos, StartInput
    Library:GiveSignal(DragFrame.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = true; StartInput = Input.Position; StartPos = UI.Position
        end
    end))
    Library:GiveSignal(UserInputService.InputChanged:Connect(function(Input)
        if Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then
            local Delta = Input.Position - StartInput
            UI.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
        end
    end))
    Library:GiveSignal(UserInputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
    end))
end

--// Base Groupbox (Object-Oriented) \\--
local BaseGroupbox = {}
do
    local Funcs = {}

    function Funcs:AddSubLabel(Text)
        local Lbl = New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 16),
            Text = string.upper(Text),
            TextColor3 = Library.Scheme.Muted,
            TextSize = 10,
            FontFace = Font.fromEnum(Enum.Font.RobotoMono, Enum.FontWeight.Bold),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = self.Container
        })
        self:Resize()
        return Lbl
    end

    function Funcs:AddToggle(Idx, Info)
        Info = Library:Validate(Info, Templates.Toggle)
        local Toggle = { Value = Info.Default, Type = "Toggle" }
        
        local Holder = New("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, Info.Desc and 36 or 22),
            Parent = self.Container
        })
        CreateTitleAndDesc(Holder, Info.Text, Info.Desc)
        
        local Btn = New("TextButton", {
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(1, 1),
            Text = "", ZIndex = 2,
            Parent = Holder
        })
        
        local SwitchBg = New("Frame", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, 0, 0.5, 0),
            Size = UDim2.fromOffset(30, 16),
            BackgroundColor3 = Toggle.Value and Library.Scheme.Accent or Library.Scheme.Background,
            Parent = Holder
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SwitchBg })
        New("UIStroke", { Color = Library.Scheme.Outline, Parent = SwitchBg })
        
        local SwitchCircle = New("Frame", {
            AnchorPoint = Vector2.new(Toggle.Value and 1 or 0, 0.5),
            Position = UDim2.new(Toggle.Value and 1 or 0, Toggle.Value and -2 or 2, 0.5, 0),
            Size = UDim2.fromOffset(12, 12),
            BackgroundColor3 = Color3.new(1, 1, 1),
            Parent = SwitchBg
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SwitchCircle })

        local function Update()
            TweenService:Create(SwitchBg, Library.TweenInfo, { BackgroundColor3 = Toggle.Value and Library.Scheme.Accent or Library.Scheme.Background }):Play()
            TweenService:Create(SwitchCircle, Library.TweenInfo, { 
                AnchorPoint = Vector2.new(Toggle.Value and 1 or 0, 0.5),
                Position = UDim2.new(Toggle.Value and 1 or 0, Toggle.Value and -2 or 2, 0.5, 0)
            }):Play()
            if Info.Callback then task.spawn(Info.Callback, Toggle.Value) end
        end

        Btn.MouseButton1Click:Connect(function() Toggle.Value = not Toggle.Value; Update() end)
        function Toggle:SetValue(val) Toggle.Value = val; Update() end
        
        self:Resize()
        return Toggle
    end

    function Funcs:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Slider = { Value = Info.Default, Min = Info.Min, Max = Info.Max, Type = "Slider" }
        local Format = "%." .. Info.Decimals .. "f"
        
        local Holder = New("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 36),
            Parent = self.Container
        })
        
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 14),
            Text = Info.Text,
            TextColor3 = Library.Scheme.Text,
            TextSize = 12, FontFace = Library.Scheme.Font,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Holder
        })
        
        local ValLabel = New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 14),
            Text = string.format(Format, Slider.Value) .. (Info.Suffix ~= "" and " " .. Info.Suffix or ""),
            TextColor3 = Library.Scheme.Accent,
            TextSize = 12, FontFace = Library.Scheme.Font,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = Holder
        })
        
        local BarBg = New("TextButton", {
            AnchorPoint = Vector2.new(0, 1),
            Position = UDim2.new(0, 0, 1, -4),
            Size = UDim2.new(1, 0, 0, 4),
            BackgroundColor3 = Library.Scheme.Outline,
            Text = "", AutoButtonColor = false,
            Parent = Holder
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = BarBg })
        
        local Fill = New("Frame", {
            Size = UDim2.fromScale(math.clamp((Slider.Value - Slider.Min) / (Slider.Max - Slider.Min), 0, 1), 1),
            BackgroundColor3 = Library.Scheme.Accent,
            Parent = BarBg
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })
        
        local Handle = New("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(1, 0, 0.5, 0),
            Size = UDim2.fromOffset(10, 10),
            BackgroundColor3 = Library.Scheme.Accent,
            Parent = Fill
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Handle })
        
        local Dragging = false
        local function Update(Input)
            local Pct = math.clamp((Input.Position.X - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X, 0, 1)
            Slider.Value = tonumber(string.format(Format, Slider.Min + ((Slider.Max - Slider.Min) * Pct)))
            Fill.Size = UDim2.fromScale(Pct, 1)
            ValLabel.Text = string.format(Format, Slider.Value) .. (Info.Suffix ~= "" and " " .. Info.Suffix or "")
            if Info.Callback then task.spawn(Info.Callback, Slider.Value) end
        end

        BarBg.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true; Update(Input) end
        end)
        UserInputService.InputEnded:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
        end)
        UserInputService.InputChanged:Connect(function(Input)
            if Dragging and Input.UserInputType == Enum.UserInputType.MouseMovement then Update(Input) end
        end)

        function Slider:SetValue(val)
            Slider.Value = math.clamp(tonumber(string.format(Format, val)), Slider.Min, Slider.Max)
            Fill.Size = UDim2.fromScale((Slider.Value - Slider.Min) / (Slider.Max - Slider.Min), 1)
            ValLabel.Text = string.format(Format, Slider.Value) .. (Info.Suffix ~= "" and " " .. Info.Suffix or "")
            if Info.Callback then task.spawn(Info.Callback, Slider.Value) end
        end
        
        self:Resize()
        return Slider
    end

    function Funcs:AddDropdown(Idx, Info)
        Info = Library:Validate(Info, Templates.Dropdown)
        local Dropdown = { Value = Info.Default or Info.Items[1], Open = false, Type = "Dropdown" }
        
        local Holder = New("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, Info.Desc and 54 or 40),
            Parent = self.Container
        })
        local TopArea = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, Info.Desc and 24 or 14), Parent = Holder })
        CreateTitleAndDesc(TopArea, Info.Text, Info.Desc)
        
        local Box = New("TextButton", {
            AnchorPoint = Vector2.new(0, 1),
            Position = UDim2.new(0, 0, 1, 0),
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = Library.Scheme.Element,
            Text = "  " .. tostring(Dropdown.Value),
            TextColor3 = Library.Scheme.Text,
            TextSize = 11, FontFace = Library.Scheme.Font, TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
            Parent = Holder
        })
        New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Box })
        New("UIStroke", { Color = Library.Scheme.Outline, Parent = Box })
        
        local Chevron = New("ImageLabel", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -6, 0.5, 0),
            Size = UDim2.fromOffset(16, 16),
            BackgroundTransparency = 1,
            ImageColor3 = Library.Scheme.Muted,
            Parent = Box
        })
        local CIcon = Library:GetIcon("chevron-down")
        if CIcon then Chevron.Image = CIcon.Url; Chevron.ImageRectOffset = CIcon.ImageRectOffset; Chevron.ImageRectSize = CIcon.ImageRectSize end
        
        local ListHolder = New("Frame", {
            Position = UDim2.new(0, 0, 1, 4),
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Library.Scheme.Element,
            Visible = false, ZIndex = 10,
            Parent = Box
        })
        New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = ListHolder })
        New("UIStroke", { Color = Library.Scheme.Outline, Parent = ListHolder })
        local ListLayout = New("UIListLayout", { Padding = UDim.new(0, 2), Parent = ListHolder })
        New("UIPadding", { PaddingTop = UDim.new(0,4), PaddingBottom = UDim.new(0,4), PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4), Parent = ListHolder })

        local function BuildList()
            for _, v in pairs(ListHolder:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            for _, item in ipairs(Info.Items) do
                local Btn = New("TextButton", {
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundColor3 = (Dropdown.Value == item) and Library.Scheme.Hover or Library.Scheme.Element,
                    Text = "  " .. tostring(item),
                    TextColor3 = (Dropdown.Value == item) and Library.Scheme.Accent or Library.Scheme.Muted,
                    TextSize = 11, FontFace = Library.Scheme.Font, TextXAlignment = Enum.TextXAlignment.Left,
                    AutoButtonColor = false, ZIndex = 11,
                    Parent = ListHolder
                })
                New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Btn })
                Btn.MouseButton1Click:Connect(function()
                    Dropdown.Value = item; Dropdown.Open = false
                    Box.Text = "  " .. tostring(item)
                    ListHolder.Visible = false
                    BuildList()
                    if Info.Callback then task.spawn(Info.Callback, Dropdown.Value) end
                end)
            end
            ListHolder.Size = UDim2.new(1, 0, 0, ListLayout.AbsoluteContentSize.Y + 8)
        end

        Box.MouseButton1Click:Connect(function()
            Dropdown.Open = not Dropdown.Open
            ListHolder.Visible = Dropdown.Open
            BuildList()
        end)
        
        function Dropdown:SetValue(val) Dropdown.Value = val; Box.Text = "  " .. tostring(val); BuildList() end
        function Dropdown:SetItems(items) Info.Items = items; BuildList() end

        BuildList()
        self:Resize()
        return Dropdown
    end

    BaseGroupbox.__index = Funcs
end

