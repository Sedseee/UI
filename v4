    local ScreenGui = New("ScreenGui", { Name = "SynqUI", ResetOnSpawn = false, DisplayOrder = 100 })
    ScreenGui.Parent = get_ui_parent()
    Library.ScreenGui = ScreenGui

    local MainFrame = New("Frame", {
        AnchorPoint = WindowInfo.Center and Vector2.new(0.5, 0.5) or Vector2.new(0, 0),
        Position = WindowInfo.Center and UDim2.new(0.5, 0, 0.5, 0) or UDim2.new(0, 50, 0, 50),
        Size = WindowInfo.Size,
        BackgroundColor3 = Library.Scheme.Background,
        Parent = ScreenGui
    })
    New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = MainFrame })
    New("UIStroke", { Color = Library.Scheme.Outline, Parent = MainFrame })

    local Topbar = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 35), Parent = MainFrame })
    Library:MakeDraggable(MainFrame, Topbar)

    local CloseBtn = New("TextButton", { AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -15, 0.5, 0), Size = UDim2.fromOffset(20, 20), BackgroundTransparency = 1, Text = "X", TextColor3 = Library.Scheme.Muted, FontFace = Library.Scheme.Font, Parent = Topbar })
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    local Sidebar = New("Frame", {
        Size = UDim2.new(0, 90, 1, 0),
        BackgroundColor3 = Library.Scheme.Sidebar,
        Parent = MainFrame
    })
    New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Sidebar })
    New("Frame", { Size = UDim2.new(0, 6, 1, 0), Position = UDim2.new(1, -6, 0, 0), BackgroundColor3 = Library.Scheme.Sidebar, BorderSizePixel = 0, Parent = Sidebar }) -- Connect to main area
    New("UIStroke", { Color = Library.Scheme.Outline, Parent = Sidebar })

    local Logo = New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 15),
        Size = UDim2.new(1, 0, 0, 20),
        Text = WindowInfo.Title,
        TextColor3 = Library.Scheme.Accent,
        TextSize = 14,
        FontFace = Font.fromEnum(Enum.Font.RobotoMono, Enum.FontWeight.Bold),
        Parent = Sidebar
    })

    local TabContainer = New("ScrollingFrame", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 55),
        Size = UDim2.new(1, 0, 1, -55),
        ScrollBarThickness = 0,
        Parent = Sidebar
    })
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5), Parent = TabContainer })

    local ContentContainer = New("Frame", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 95, 0, 40),
        Size = UDim2.new(1, -100, 1, -45),
        Parent = MainFrame
    })

    local Window = { ActiveTab = nil }

    function Window:AddTab(Name, IconName)
        local TabBtn = New("TextButton", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 50),
            Text = "",
            Parent = TabContainer
        })
        
        local Indicator = New("Frame", {
            BackgroundColor3 = Library.Scheme.Accent,
            Size = UDim2.new(0, 2, 0, 20),
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 0, 0.5, 0),
            BackgroundTransparency = 1,
            Parent = TabBtn
        })
        
        local IconImage = New("ImageLabel", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(0.5, 0),
            Position = UDim2.new(0.5, 0, 0, 5),
            Size = UDim2.fromOffset(18, 18),
            ImageColor3 = Library.Scheme.Muted,
            Parent = TabBtn
        })
        local TIcon = Library:GetIcon(IconName or "lucide:layout-grid")
        if TIcon then IconImage.Image = TIcon.Url; IconImage.ImageRectOffset = TIcon.ImageRectOffset; IconImage.ImageRectSize = TIcon.ImageRectSize end
        
        local TabLbl = New("TextLabel", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(0.5, 1),
            Position = UDim2.new(0.5, 0, 1, -5),
            Size = UDim2.new(1, 0, 0, 12),
            Text = string.lower(Name),
            TextColor3 = Library.Scheme.Muted,
            TextSize = 10,
            FontFace = Library.Scheme.Font,
            Parent = TabBtn
        })

        local Page = New("ScrollingFrame", {
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(1, 1),
            ScrollBarThickness = 0,
            Visible = false,
            Parent = ContentContainer
        })
        local DualLayout = New("Frame", { BackgroundTransparency = 1, Size = UDim2.fromScale(1, 1), Parent = Page })
        local LeftCol = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0.5, -5, 1, 0), Position = UDim2.new(0, 0, 0, 0), Parent = DualLayout })
        local RightCol = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0.5, -5, 1, 0), Position = UDim2.new(0.5, 5, 0, 0), Parent = DualLayout })
        
        local LeftLayout = New("UIListLayout", { Padding = UDim.new(0, 10), Parent = LeftCol })
        local RightLayout = New("UIListLayout", { Padding = UDim.new(0, 10), Parent = RightCol })
        
        local function TrackPageHeight()
            local maxH = math.max(LeftLayout.AbsoluteContentSize.Y, RightLayout.AbsoluteContentSize.Y)
            Page.CanvasSize = UDim2.new(0, 0, 0, maxH + 20)
        end
        LeftLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(TrackPageHeight)
        RightLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(TrackPageHeight)

        local Tab = { Page = Page, Left = LeftCol, Right = RightCol, Groupboxes = {} }

        TabBtn.MouseButton1Click:Connect(function()
            if Window.ActiveTab then
                Window.ActiveTab.Page.Visible = false
                Window.ActiveTab.Indicator.BackgroundTransparency = 1
                Window.ActiveTab.Icon.ImageColor3 = Library.Scheme.Muted
                Window.ActiveTab.Label.TextColor3 = Library.Scheme.Muted
            end
            Page.Visible = true
            Indicator.BackgroundTransparency = 0
            IconImage.ImageColor3 = Library.Scheme.Accent
            TabLbl.TextColor3 = Library.Scheme.Accent
            Window.ActiveTab = { Page = Page, Indicator = Indicator, Icon = IconImage, Label = TabLbl }
        end)

        if not Window.ActiveTab then
            Page.Visible = true
            Indicator.BackgroundTransparency = 0
            IconImage.ImageColor3 = Library.Scheme.Accent
            TabLbl.TextColor3 = Library.Scheme.Accent
            Window.ActiveTab = { Page = Page, Indicator = Indicator, Icon = IconImage, Label = TabLbl }
        end

        function Tab:AddGroupbox(Info)
            local Box = New("Frame", {
                BackgroundColor3 = Library.Scheme.Section,
                Size = UDim2.new(1, 0, 0, 0),
                Parent = Info.Side == 1 and LeftCol or RightCol
            })
            New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Box })
            New("UIStroke", { Color = Library.Scheme.Outline, Parent = Box })
            
            local Header = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), Parent = Box })
            local Square = New("Frame", { Size = UDim2.fromOffset(4, 4), Position = UDim2.new(0, 12, 0.5, -2), BackgroundColor3 = Library.Scheme.Accent, BorderSizePixel = 0, Parent = Header })
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 24, 0, 0),
                Size = UDim2.new(1, -24, 1, 0),
                Text = string.lower(Info.Name),
                TextColor3 = Library.Scheme.Muted,
                TextSize = 11, FontFace = Library.Scheme.Font, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Header
            })
            New("Frame", { BackgroundColor3 = Library.Scheme.Outline, Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -1), BorderSizePixel=0, Parent = Header })

            local Container = New("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 26), Size = UDim2.new(1, 0, 1, -26), Parent = Box })
            local Layout = New("UIListLayout", { Padding = UDim.new(0, 8), Parent = Container })
            New("UIPadding", { PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), Parent = Container })
            
            local Groupbox = { Container = Container }
            function Groupbox:Resize() Box.Size = UDim2.new(1, 0, 0, Layout.AbsoluteContentSize.Y + 44) end
            Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() Groupbox:Resize() end)
            
            setmetatable(Groupbox, BaseGroupbox)
            table.insert(Tab.Groupboxes, Groupbox)
            return Groupbox
        end

        function Tab:AddLeftGroupbox(Name) return self:AddGroupbox({ Side = 1, Name = Name }) end
        function Tab:AddRightGroupbox(Name) return self:AddGroupbox({ Side = 2, Name = Name }) end

        table.insert(Library.Tabs, Tab)
        return Tab
    end

    -- Toggle Hotkey
    UserInputService.InputBegan:Connect(function(Input, Processed)
        if not Processed and Input.KeyCode == Enum.KeyCode.RightControl then
            Library.Toggled = not Library.Toggled
            MainFrame.Visible = Library.Toggled
        end
    end)

    return Window
end

return Library 
