    function Class:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Container = self.Container
        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 42), Parent = Container })
        
        New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 5), Size = UDim2.new(0.5, 0, 0, 14), Text = Info.Text:lower(), TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        local ValLab = New("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1, 0, 0, 5), Size = UDim2.new(0.5, 0, 0, 14), Text = "", TextSize = 11, TextColor3 = "AccentColor", TextXAlignment = Enum.TextXAlignment.Right, FontFace = "Font", Parent = Holder })
        
        local InteractObj = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 0, 1, 0), Size = UDim2.new(1, 0, 0, 18), Text = "", Parent = Holder })
        
        local BaseBar = New("Frame", { BackgroundColor3 = "OutlineColor", AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.5, 0), Size = UDim2.new(1, 0, 0, 2), Parent = InteractObj })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = BaseBar })
        
        local Fill = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0, 0, 1, 0), Parent = BaseBar })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })
        local Grip = New("Frame", { BackgroundColor3 = "AccentColor", AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.fromOffset(10, 10), Parent = Fill })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Grip })

        local SliderObj = { Value = Info.Default, Type = "Slider" }

        function SliderObj:UpdateDisplay()
            local Compct = math.clamp((SliderObj.Value - Info.Min) / (Info.Max - Info.Min), 0, 1)
            ValLab.Text = tostring(SliderObj.Value) .. Info.Suffix
            Fill.Size = UDim2.new(Compct, 0, 1, 0)
        end
        function SliderObj:SetValue(Val)
            Val = math.clamp(Val, Info.Min, Info.Max)
            if Info.Rounding > 0 then
                local multi = 10 ^ Info.Rounding; Val = math.floor(Val * multi + 0.5) / multi
            else Val = math.floor(Val + 0.5) end
            
            SliderObj.Value = Val
            SliderObj:UpdateDisplay()
            Library:SafeCallback(Info.Callback, Val)
        end

        local DraggingSlider
        InteractObj.InputBegan:Connect(function(Imp)
            if Imp.UserInputType == Enum.UserInputType.MouseButton1 or Imp.UserInputType == Enum.UserInputType.Touch then
                DraggingSlider = true
                while DraggingSlider and RunService.RenderStepped:Wait() do
                    -- Fallback positional checking that avoids complex bounds offsetting.
                    local ScaleBounds = InteractObj.AbsolutePosition.X
                    local ScreenMouse = UserInputService:GetMouseLocation().X
                    local Perc = math.clamp((ScreenMouse - ScaleBounds) / InteractObj.AbsoluteSize.X, 0, 1)
                    SliderObj:SetValue(Info.Min + ((Info.Max - Info.Min) * Perc))
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(Imp)
            if Imp.UserInputType == Enum.UserInputType.MouseButton1 or Imp.UserInputType == Enum.UserInputType.Touch then DraggingSlider = false end
        end)

        SliderObj:UpdateDisplay(); self:Resize()
        table.insert(self.Elements, SliderObj); Library.Options[Idx] = SliderObj
        return SliderObj
    end

