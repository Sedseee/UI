        -- Exact width margins mapped. Total 100%. 0.5 ensures perfectly mapped boxes!
        local Lx = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0.5, -6, 1, 0), Parent = RenderPageBody })
        local Rx = New("Frame", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0.5, -6, 1, 0), Parent = RenderPageBody })
        
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 14), Parent = Lx })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 14), Parent = Rx })

        local CurCtxt = { MainPage = RenderPageBody, ColumnL = Lx, ColumnR = Rx }
        
        TTb.MouseButton1Click:Connect(function()
            if Library.RefSysTab then
                Library.RefSysTab.IconInstance.ImageColor3 = Library.Scheme.SecondaryColor
                Library.RefSysTab.LabelInstance.TextColor3 = Library.Scheme.SecondaryColor
                Library.RefSysTab.IndicatorInstance.Visible = false
                Library.RefSysTab.PageInstance.Visible = false
            end
            IcoRef.ImageColor3 = Library.Scheme.AccentColor
            TitleRef.TextColor3 = Library.Scheme.FontColor
            TargetIndicator.Visible = true; RenderPageBody.Visible = true
            Library.RefSysTab = { IconInstance = IcoRef, LabelInstance = TitleRef, IndicatorInstance = TargetIndicator, PageInstance = RenderPageBody }
        end)

        if not Library.RefSysTab then 
            IcoRef.ImageColor3 = Library.Scheme.AccentColor
            TitleRef.TextColor3 = Library.Scheme.FontColor
            TargetIndicator.Visible = true; RenderPageBody.Visible = true
            Library.RefSysTab = { IconInstance = IcoRef, LabelInstance = TitleRef, IndicatorInstance = TargetIndicator, PageInstance = RenderPageBody }
        end

        function CurCtxt:AddGroup(TitleG, AlignmentID)
            local TrzCol = AlignmentID == 2 and Rx or Lx
            local Grpx = New("Frame", { BackgroundColor3 = "MainColor", Size = UDim2.new(1, 0, 0, 100), Parent = TrzCol })
            New("UICorner", { CornerRadius = UDim.new(0, 5), Parent = Grpx })
            New("UIStroke", { Color = "OutlineColor", Parent = Grpx })
            
            local HTlO = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 32), Parent = Grpx })
            New("Frame", { BackgroundColor3 = "AccentColor", Position = UDim2.fromOffset(12, 14), Size = UDim2.fromOffset(4, 4), Parent = HTlO })
            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(26, 0), Size = UDim2.new(1, -26, 1, 0), Text = TitleG:lower(), TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = HTlO })
            New("Frame", { BackgroundColor3 = "OutlineColor", Position = UDim2.new(0, 12, 1, -1), Size = UDim2.new(1, -24, 0, 1), Parent = HTlO })

            local PContainer = New("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 32), Size = UDim2.new(1, 0, 1, -32), Parent = Grpx })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = PContainer })
            New("UIPadding", { PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 14), Parent = PContainer })

            local MasterOut = { Holder = Grpx, Container = PContainer, Elements = {}, TabObj = CurCtxt }
            setmetatable(MasterOut, GBLayout)
            MasterOut:Resize()
            return MasterOut
        end

        function CurCtxt:AddLeftGroupbox(S_NamesGroup) return CurCtxt:AddGroup(S_NamesGroup, 1) end
        function CurCtxt:AddRightGroupbox(S_NamesGroup) return CurCtxt:AddGroup(S_NamesGroup, 2) end

        return CurCtxt
    end

    UserInputService.InputBegan:Connect(function(Imp)
        if Imp.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end)
    return UIStateObj
end

getgenv().Library = Library
return Library
