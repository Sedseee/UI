        local DropWindow = New("ScrollingFrame", { BackgroundColor3 = "MainColor", Visible = false, Size = UDim2.new(0, 100, 0, 0), ScrollBarThickness = 1, CanvasSize = UDim2.new(), ZIndex = 15, Parent = ScreenGui })
