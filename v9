local GBLayout = setmetatable({}, ElementsClass)
function GBLayout:Resize()
    local HeightTracking = 0
    for _, El in ipairs(self.Container:GetChildren()) do
        if El:IsA("GuiObject") and El.Visible then
            HeightTracking = HeightTracking + El.AbsoluteSize.Y + 6 -- Accounting UIListLayout Padding explicitly
        end
    end
    self.Holder.Size = UDim2.new(1, 0, 0, HeightTracking + 40)
    
    if self.TabObj and self.TabObj.MainPage then
        local L, R = self.TabObj.ColumnL, self.TabObj.ColumnR
        local SzeX = L:FindFirstChildOfClass("UIListLayout")
        local SzeY = R:FindFirstChildOfClass("UIListLayout")
        if SzeX and SzeY then
            self.TabObj.MainPage.CanvasSize = UDim2.new(0, 0, 0, math.max(SzeX.AbsoluteContentSize.Y, SzeY.AbsoluteContentSize.Y) + 30)
        end
    end
end
GBLayout.__index = GBLayout

