        local Dropdo = { Value = Info.Multi and {} or Info.Default, Type = "Dropdown" }
        local MenuActive = false

        function Dropdo:UpdateLabels()
            local labelConstruct = ""
            if Info.Multi then
                local tabS = {}
                for k,v in pairs(Dropdo.Value) do if v then table.insert(tabS, k) end end
                labelConstruct = #tabS > 0 and table.concat(tabS, ", ") or "Off"
            else
                labelConstruct = Dropdo.Value or "Off"
            end
            Disp.Text = " " .. labelConstruct
        end

        function Dropdo:SyncRenderOptions()
            for _, Chd in pairs(DropWindow:GetChildren()) do if Chd:IsA("TextButton") then Chd:Destroy() end end
            local AbsoluteLen = 6
            for _, TxtMap in ipairs(Info.Values) do
                local BttnTemp = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 24), Text = tostring(TxtMap), TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = "FontColor", TextSize = 11, FontFace = "Font", ZIndex = 16, Parent = DropWindow })
                New("UIPadding", { PaddingLeft = UDim.new(0, 10), Parent = BttnTemp })
                BttnTemp.MouseButton1Click:Connect(function()
                    if Info.Multi then Dropdo.Value[TxtMap] = not Dropdo.Value[TxtMap] else Dropdo.Value = TxtMap; MenuActive = false end
                    Dropdo:UpdateLabels(); Library:SafeCallback(Info.Callback, Dropdo.Value)
                    if not MenuActive then DropWindow.Visible = false end
                end)
                AbsoluteLen = AbsoluteLen + 26
            end
            DropWindow.CanvasSize = UDim2.new(0,0,0,AbsoluteLen); DropWindow.Size = UDim2.new(0, Disp.AbsoluteSize.X, 0, math.clamp(AbsoluteLen, 0, 160))
        end

        Disp.MouseButton1Click:Connect(function()
            MenuActive = not MenuActive
            if MenuActive then
                DropWindow.Position = UDim2.new(0, Disp.AbsolutePosition.X, 0, Disp.AbsolutePosition.Y + 30)
                DropWindow.Size = UDim2.new(0, Disp.AbsoluteSize.X, 0, DropWindow.Size.Y.Offset)
            end
            DropWindow.Visible = MenuActive
        end)

        Dropdo:SyncRenderOptions(); Dropdo:UpdateLabels(); self:Resize()
        table.insert(self.Elements, Dropdo); Library.Options[Idx] = Dropdo
        return Dropdo
    end

