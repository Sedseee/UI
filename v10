-- Layout Processor Frame Updates
local CntLayout = setmetatable({}, BaseAddons)
function CntLayout:Resize()
    local HeightAccum = 0
    for _, Eml in ipairs(self.Container:GetChildren()) do
        if Eml:IsA("GuiObject") and Eml.Visible then HeightAccum = HeightAccum + Eml.AbsoluteSize.Y + 8 end
    end
    self.Holder.Size = UDim2.new(1, 0, 0, HeightAccum + 38)
    
    if self.TabObj and self.TabObj.MainPage then
        local L, R = self.TabObj.ColumnL:FindFirstChildOfClass("UIListLayout"), self.TabObj.ColumnR:FindFirstChildOfClass("UIListLayout")
        self.TabObj.MainPage.CanvasSize = UDim2.new(0, 0, 0, math.max(L and L.AbsoluteContentSize.Y or 0, R and R.AbsoluteContentSize.Y or 0) + 60)
    end
end
CntLayout.__index = CntLayout

