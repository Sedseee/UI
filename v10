    function Funcs:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Sld = { Value = Info.Default, Type = "Slider" }

        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 36), Parent = self.Container }) 
        New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 2), Size = UDim2.new(0.65, 0, 0, 12), Text = Info.Text:upper(), TextSize = 10, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        local ValRef = New("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1, 0, 0, 2), Size = UDim2.new(0.35, 0, 0, 12), Text = "", TextSize = 10, TextColor3 = "AccentColor", TextXAlignment = Enum.TextXAlignment.Right, FontFace = "Font", Parent = Holder })
        
        local BarZone = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 0, 1, 0), Size = UDim2.new(1, 0, 0, 16), Text = "", Parent = Holder })
        local BarLine = New("Frame", { BackgroundColor3 = "MainColor", AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.5, 0), Size = UDim2.new(1, 0, 0, 6), Parent = BarZone })
        New("UIStroke", { Color = "OutlineColor", Parent = BarLine })
        New("UICorner", { CornerRadius = UDim.new(0, Library.CornerRadius), Parent = BarLine })
        
        -- Flat filling line completely eliminating Knob (Clean visual loading layout)
        local FilCol = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0, 0, 1, 0), Parent = BarLine })
        New("UICorner", { CornerRadius = UDim.new(0, Library.CornerRadius), Parent = FilCol })

        function Sld:UpdateDisp()
            local TrM = math.clamp((Sld.Value - Info.Min) / (Info.Max - Info.Min), 0, 1)
            ValRef.Text = "["..tostring(Sld.Value) .. Info.Suffix.."]"; FilCol.Size = UDim2.new(TrM, 0, 1, 0)
        end
        function Sld:SetValue(ValIn)
            local FltCmb = math.clamp(ValIn, Info.Min, Info.Max)
            if Info.Rounding > 0 then local Mlb = 10 ^ Info.Rounding; FltCmb = math.floor(FltCmb * Mlb + 0.5) / Mlb
            else FltCmb = math.floor(FltCmb + 0.5) end
            
            Sld.Value = FltCmb; Sld:UpdateDisp(); Library:SafeCallback(Info.Callback, FltCmb)
        end

        local LocDrag = false
        BarZone.InputBegan:Connect(function(IoPs)
            if IoPs.UserInputType == Enum.UserInputType.MouseButton1 or IoPs.UserInputType == Enum.UserInputType.Touch then
                LocDrag = true
                while LocDrag and RunService.RenderStepped:Wait() do
                    local ActMoZ = UserInputService:GetMouseLocation().X
                    local FinPc = math.clamp((ActMoZ - BarZone.AbsolutePosition.X) / BarZone.AbsoluteSize.X, 0, 1)
                    Sld:SetValue(Info.Min + ((Info.Max - Info.Min) * FinPc))
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(IoPs) if IoPs.UserInputType == Enum.UserInputType.MouseButton1 or IoPs.UserInputType == Enum.UserInputType.Touch then LocDrag = false end end)

        Sld:UpdateDisp(); self:Resize()
        table.insert(self.Elements, Sld); Library.Options[Idx] = Sld; return Sld
    end

