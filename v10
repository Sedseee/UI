        local VTitbStO = New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 26, 0, 0), Size = UDim2.new(1, -26, 1, 0), Text = LabelTrf:lower(), TextSize = 10, TextColor3 = "SecondaryColor", TextXAlignment=Enum.TextXAlignment.Left, FontFace = "Font", Parent = TnBtOut })

        local RPSectBodyId = New("ScrollingFrame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), CanvasSize = UDim2.new(), ScrollBarThickness = 1, Visible = false, Parent = PgsWrapR })
        New("UIPadding", { PaddingTop = UDim.new(0, 20), PaddingBottom = UDim.new(0, 20), PaddingLeft = UDim.new(0, 16), PaddingRight = UDim.new(0, 16), Parent = RPSectBodyId })
        
        local PL_Col = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0.5, -6, 1, 0), Parent = RPSectBodyId })
        local PR_Col = New("Frame", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1,0,0,0), Size = UDim2.new(0.5, -6, 1, 0), Parent = RPSectBodyId })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 14), Parent = PL_Col })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 14), Parent = PR_Col })

        local CurTbIntDct = { MainPage = RPSectBodyId, ColumnL = PL_Col, ColumnR = PR_Col }
        
        local function EnableThisTab()
            if Library.MdtCtxSve then
                Library.MdtCtxSve.VId.ImageColor3 = Library.Scheme.SecondaryColor; Library.MdtCtxSve.VTt.TextColor3 = Library.Scheme.SecondaryColor
                Library.MdtCtxSve.HllB.Visible = false; Library.MdtCtxSve.PnnP.Visible = false; TweenService:Create(Library.MdtCtxSve.TTrx, Library.TweenInfo, {BackgroundTransparency=1}):Play()
            end
            VIdctMap.ImageColor3 = Library.Scheme.FontColor; VTitbStO.TextColor3 = Library.Scheme.FontColor
            IndctSlid.Visible = true; RPSectBodyId.Visible = true; TweenService:Create(TnBtOut, Library.TweenInfo, {BackgroundTransparency=0.85}):Play()
            Library.MdtCtxSve = { VId=VIdctMap, VTt=VTitbStO, HllB=IndctSlid, PnnP=RPSectBodyId, TTrx=TnBtOut }
        end
        
        TnBtOut.MouseButton1Click:Connect(EnableThisTab)
        if not Library.MdtCtxSve then EnableThisTab() end

        function CurTbIntDct:AddGroup(TitleTrkDt, AlignOrds)
            local TrsColTg = AlignOrds == 2 and PR_Col or PL_Col
            local GbOutBound = New("Frame", { BackgroundColor3 = "MainColor", Size = UDim2.new(1, 0, 0, 100), Parent = TrsColTg })
            New("UIStroke", { Color="OutlineColor", Parent=GbOutBound}); New("UICorner", { CornerRadius=UDim.new(0, Library.CornerRadius), Parent=GbOutBound })
            
            -- Brisk Bold Top Label Stroke Tracker Setup instead of underline
            local GpTrSlyf = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 26), Parent = GbOutBound })
            New("Frame", { BackgroundColor3 = "AccentColor", Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -20, 0, 1), Parent = GpTrSlyf })
            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(12, 4), Size = UDim2.new(1,-24,1, -4), Text = TitleTrkDt:lower(), TextSize = 10, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = GpTrSlyf })

            local CtPackRff = New("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 26), Size = UDim2.new(1, 0, 1, -26), Parent = GbOutBound })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = CtPackRff })
            New("UIPadding", { PaddingTop = UDim.new(0, 5), PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), Parent = CtPackRff })

            local MMvRxCt = { Holder = GbOutBound, Container = CtPackRff, Elements = {}, TabObj = CurTbIntDct }
            setmetatable(MMvRxCt, CntLayout); MMvRxCt:Resize(); return MMvRxCt
        end

        function CurTbIntDct:AddLeftGroupbox(SxP) return CurTbIntDct:AddGroup(SxP, 1) end
        function CurTbIntDct:AddRightGroupbox(SxP) return CurTbIntDct:AddGroup(SxP, 2) end

        return CurTbIntDct
    end

    UserInputService.InputBegan:Connect(function(Imp) if Imp.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then ScreenGui.Enabled = not ScreenGui.Enabled end end)
    return MntUX
end

getgenv().Library = Library
return Library
