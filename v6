local BaseGroupbox = {}
do
    local Funcs = setmetatable({}, BaseAddons)
    function Funcs:Resize()
        local height = 0
        for _, child in ipairs(self.Container:GetChildren()) do
            if child:IsA("GuiObject") and child.Visible then height = height + child.AbsoluteSize.Y + 6 end
        end
        self.Holder.Size = UDim2.new(1, 0, 0, height + 36)
        
        -- Adjust Canvas Size of the parent Tab
        if self.Tab and self.Tab.Page then
            local Layout1 = self.Tab.LeftCol.UIListLayout
            local Layout2 = self.Tab.RightCol.UIListLayout
            self.Tab.Page.CanvasSize = UDim2.new(0, 0, 0, math.max(Layout1.AbsoluteContentSize.Y, Layout2.AbsoluteContentSize.Y) + 40)
        end
    end
    BaseGroupbox.__index = Funcs
end

function Library:CreateWindow(Info)
    Info = Library:Validate(Info, Templates.Window)
    
    -- Safe Font Handling
    if Info.Font then
        if typeof(Info.Font) == "EnumItem" then
            Library.Scheme.Font = Font.fromEnum(Info.Font)
        elseif typeof(Info.Font) == "Font" then
            Library.Scheme.Font = Info.Font
        end
    end

    local MainFrame = New("Frame", { BackgroundColor3 = "BackgroundColor", Position = Info.Position, Size = Info.Size, Active = true, Parent = ScreenGui })
    New("UICorner", { CornerRadius = UDim.new(0, Library.CornerRadius), Parent = MainFrame })
    New("UIStroke", { Color = "OutlineColor", Parent = MainFrame })

    local DragArea = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 40), Text = "", Parent = MainFrame })
    Library:MakeDraggable(MainFrame, DragArea)

    local Sidebar = New("Frame", { BackgroundColor3 = "BackgroundColor", Size = UDim2.new(0, 150, 1, 0), Parent = MainFrame })
    New("Frame", { BackgroundColor3 = "OutlineColor", Position = UDim2.new(1, -1, 0, 0), Size = UDim2.new(0, 1, 1, 0), Parent = Sidebar })
    
    New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(20, 20), Size = UDim2.new(1, -20, 0, 30), Text = Info.Title, TextSize = 16, TextColor3 = "AccentColor", FontFace = "Font", TextXAlignment = Enum.TextXAlignment.Left, Parent = Sidebar })
    
    local TabContainer = New("ScrollingFrame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 65), Size = UDim2.new(1, 0, 1, -65), ScrollBarThickness = 0, CanvasSize = UDim2.new(0,0,0,0), Parent = Sidebar })
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 0), Parent = TabContainer })
    
    local ContentContainer = New("Frame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(150, 0), Size = UDim2.new(1, -150, 1, 0), ClipsDescendants = true, Parent = MainFrame })
    
    local Window = {}
    
    function Window:AddTab(Name, IconName)
        local TabBtn = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 55), Text = "", Parent = TabContainer })
        local Indicator = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0, 2, 1, -25), AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.5, 0), Visible = false, Parent = TabBtn })
        
        local ContentWrap = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Parent = TabBtn })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5), HorizontalAlignment = Enum.HorizontalAlignment.Center, VerticalAlignment = Enum.VerticalAlignment.Center, Parent = ContentWrap })
        
        local Icon = Library:GetCustomIcon(IconName or "layout")
        local TabIcon = New("ImageLabel", { BackgroundTransparency = 1, Size = UDim2.fromOffset(18, 18), Image = Icon and Icon.Url or "", ImageRectOffset = Icon and Icon.ImageRectOffset or Vector2.zero, ImageRectSize = Icon and Icon.ImageRectSize or Vector2.zero, ImageColor3 = "SecondaryColor", Parent = ContentWrap })
        local TabLabel = New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 12), Text = Name:lower(), TextSize = 11, TextColor3 = "SecondaryColor", FontFace = "Font", Parent = ContentWrap })
        
        local TabPage = New("ScrollingFrame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), CanvasSize = UDim2.new(0,0,0,0), ScrollBarThickness = 0, Visible = false, Parent = ContentContainer })
        New("UIPadding", { PaddingTop = UDim.new(0, 25), PaddingBottom = UDim.new(0, 25), PaddingLeft = UDim.new(0, 25), PaddingRight = UDim.new(0, 25), Parent = TabPage })
        
        local LeftCol = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(0.5, -10, 1, 0), Parent = TabPage })
        local RightCol = New("Frame", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0.5, -10, 1, 0), Parent = TabPage })
        LeftCol.UIListLayout = New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 15), Parent = LeftCol })
        RightCol.UIListLayout = New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 15), Parent = RightCol })
        
        local TabData = { Elements = {}, Groupboxes = {}, Page = TabPage, LeftCol = LeftCol, RightCol = RightCol }
        
        function TabData:Show()
            if Library.ActiveTab then Library.ActiveTab:Hide() end
            Indicator.Visible = true
            TweenService:Create(TabIcon, Library.TweenInfo, { ImageColor3 = Library.Scheme.AccentColor }):Play()
            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.FontColor }):Play()
            TabPage.Visible = true
            Library.ActiveTab = TabData
        end
        
        function TabData:Hide()
            Indicator.Visible = false
            TweenService:Create(TabIcon, Library.TweenInfo, { ImageColor3 = Library.Scheme.SecondaryColor }):Play()
            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.SecondaryColor }):Play()
            TabPage.Visible = false
        end
        
        TabBtn.MouseButton1Click:Connect(function() TabData:Show() end)
        if not Library.ActiveTab then TabData:Show() end
        
        function TabData:AddGroupbox(Info)
            local ParentCol = (Info.Side or 1) == 1 and LeftCol or RightCol
            local GbHolder = New("Frame", { BackgroundColor3 = "MainColor", Size = UDim2.new(1, 0, 0, 100), Parent = ParentCol })
            New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = GbHolder })
            New("UIStroke", { Color = "OutlineColor", Parent = GbHolder })
            
            local TopLabel = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 32), Parent = GbHolder })
            New("Frame", { BackgroundColor3 = "AccentColor", Position = UDim2.fromOffset(12, 14), Size = UDim2.fromOffset(5, 5), Parent = TopLabel })
            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(24, 0), Size = UDim2.new(1, -24, 1, 0), Text = Info.Name:lower(), TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = TopLabel })
            New("Frame", { BackgroundColor3 = "OutlineColor", Position = UDim2.new(0, 12, 1, -1), Size = UDim2.new(1, -24, 0, 1), Parent = TopLabel })
            
            local GbContainer = New("Frame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 32), Size = UDim2.new(1, 0, 1, -32), Parent = GbHolder })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = GbContainer })
            New("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 14), Parent = GbContainer })
            
            local Groupbox = { Holder = GbHolder, Container = GbContainer, Elements = {}, Tab = TabData }
            setmetatable(Groupbox, BaseGroupbox)
            Groupbox:Resize()
            return Groupbox
        end
        
        function TabData:AddLeftGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 1 }) end
        function TabData:AddRightGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 2 }) end
        return TabData
    end

    UserInputService.InputBegan:Connect(function(Input)
        if Input.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            Library.Toggled = not Library.Toggled
            MainFrame.Visible = Library.Toggled
        end
    end)
    return Window
end

getgenv().Library = Library
return Library
