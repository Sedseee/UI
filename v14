function Library:create_notification(info)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Sedse Hub",
            Text = info.name or info.Text or "",
            Duration = info.duration or 2
        })
    end)
end

function Library:GetIcon(IconName)
    if not FetchIcons or type(Icons) ~= "table" then return nil end
    local ok, v = pcall(Icons.GetAsset, IconName)
    return ok and v or nil
end

function Library:GetCustomIcon(IconName)
    if type(IconName) ~= "string" and type(IconName) ~= "number" then return nil end
    if tonumber(IconName) then IconName = "rbxassetid://" .. tostring(IconName) end
    if type(IconName) == "string" and (IconName:match("rbxasset") or IconName:match("roblox%.com/asset") or IconName:match("rbxthumb://")) then
        return { Url = IconName, ImageRectOffset = Vector2.zero, ImageRectSize = Vector2.zero }
    end
    return Library:GetIcon(IconName)
end

function Library:Validate(Provided, Template)
    if type(Provided) ~= "table" then return Template end
    for k, v in pairs(Template) do
        if Provided[k] == nil then
            Provided[k] = v
        elseif type(v) == "table" and type(Provided[k]) == "table" then
            Provided[k] = Library:Validate(Provided[k], v)
        end
    end
    return Provided
end

function Library:SafeCallback(Func, ...)
    if type(Func) ~= "function" then return end
    local args = { ... }
    task.spawn(function() pcall(Func, table.unpack(args)) end)
end

local function FillInstance(Table, Inst)
    local ThemeProps = Library.Registry[Inst] or {}
    for key, value in pairs(Table) do
        if key ~= "Text" and type(value) == "string" and Library.Scheme[value] ~= nil then
            ThemeProps[key] = value
            value = Library.Scheme[value]
        end
        
        if (key == "FontFace" or key == "Font") and value == "Font" then
            pcall(function() Inst.Font = Library.Scheme.FontId end)
        else
            pcall(function() Inst[key] = value end)
        end
    end
    if next(ThemeProps) then Library.Registry[Inst] = ThemeProps end
end

local function New(ClassName, Properties)
    local Inst = Instance.new(ClassName)
    FillInstance(Properties or {}, Inst)
    return Inst
end

