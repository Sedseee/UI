function GBLayout:AddDropdown(Idx, Info)
    Info = Library:Validate(Info, Templates.Dropdown)
    local hasDesc = Info.Description and Info.Description ~= ""
    local Height  = hasDesc and 60 or 46

    local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, Height), Parent = self.Container })
    New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, 0, 0, 14), Text = Info.Text:lower(), TextSize = 12, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, Font = "Font", Parent = Holder })
    if hasDesc then
        New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 15), Size = UDim2.new(1, 0, 0, 12), Text = Info.Description:lower(), TextSize = 10, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, Font = "Font", Parent = Holder })
    end

    local Disp = New("TextButton", { BackgroundColor3 = "SubColor", AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 0, 1, 0), Size = UDim2.new(1, 0, 0, 26), Text = "", ZIndex = 3, Parent = Holder })
    New("UICorner", { CornerRadius = UDim.new(0, 5), Parent = Disp })
    New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Disp })

    local DispLabel = New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -30, 1, 0), Text = "none", TextSize = 11, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, Font = "Font", ZIndex = 4, Parent = Disp })
    local Arrow = New("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -10, 0.5, 0), Size = UDim2.fromOffset(10, 10), Text = "v", TextSize = 10, TextColor3 = "SecondaryColor", Font = "Font", ZIndex = 4, Parent = Disp })

    local DropWindow = New("ScrollingFrame", { BackgroundColor3 = "MainColor", Visible = false, Size = UDim2.new(0, 100, 0, 0), ScrollBarThickness = 2, CanvasSize = UDim2.new(), ZIndex = 50, Parent = ScreenGui })
    New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = DropWindow })
    New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = DropWindow })
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = DropWindow })
    New("UIPadding", { PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6), Parent = DropWindow })

    local Dropdo = { Value = Info.Multi and {} or Info.Default, Type = "Dropdown" }
    local MenuActive = false
    local dropConn = nil

    local function updateDropPos()
        DropWindow.Position = UDim2.new(0, Disp.AbsolutePosition.X, 0, Disp.AbsolutePosition.Y + Disp.AbsoluteSize.Y + 4)
    end

    local function closeMenu()
        MenuActive = false
        DropWindow.Visible = false
        if dropConn then dropConn:Disconnect(); dropConn = nil end
        TweenService:Create(Arrow, Library.TweenInfo, { Rotation = 0 }):Play()
    end

    function Dropdo:UpdateLabels()
        local label = "none"
        if Info.Multi then
            local t = {}
            for k, v in pairs(self.Value) do if v then table.insert(t, tostring(k)) end end
            label = #t > 0 and table.concat(t, ", ") or "none"
        else
            label = self.Value and tostring(self.Value) or "none"
        end
        DispLabel.Text = label
    end

    function Dropdo:SyncRenderOptions()
        for _, c in pairs(DropWindow:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        local total = 12
        for _, val in ipairs(Info.Values) do
            local Btn = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 24), Text = tostring(val), TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = "SecondaryColor", TextSize = 11, Font = "Font", ZIndex = 51, Parent = DropWindow })
            New("UIPadding", { PaddingLeft = UDim.new(0, 12), Parent = Btn })

            local function refresh()
                local sel = Info.Multi and self.Value[val] or self.Value == val
                Btn.TextColor3 = sel and Library.Scheme.AccentColor or Library.Scheme.SecondaryColor
            end
            refresh()

            Btn.MouseEnter:Connect(function() Btn.BackgroundTransparency = 0.8; Btn.BackgroundColor3 = Library.Scheme.SubColor end)
            Btn.MouseLeave:Connect(function() Btn.BackgroundTransparency = 1 end)

            Btn.MouseButton1Click:Connect(function()
                if Info.Multi then
                    self.Value[val] = not self.Value[val]
                else
                    self.Value = val
                    closeMenu()
                end
                refresh()
                self:UpdateLabels()
                Library:SafeCallback(Info.Callback, self.Value)
            end)
            total = total + 26
        end
        DropWindow.CanvasSize = UDim2.new(0, 0, 0, total)
        DropWindow.Size = UDim2.new(0, Disp.AbsoluteSize.X, 0, math.clamp(total, 0, 160))
    end

    function Dropdo:set_items(newVals)
        Info.Values = newVals
        if not Info.Multi and not table.find(newVals, self.Value) then 
            self.Value = newVals[1] 
        end
        self:SyncRenderOptions()
        self:UpdateLabels()
    end

    function Dropdo:SetValue(val)
        self.Value = val
        self:SyncRenderOptions()
        self:UpdateLabels()
    end
    function Dropdo:set(val) self:SetValue(val) end

    Disp.MouseButton1Click:Connect(function()
        MenuActive = not MenuActive
        if MenuActive then
            Dropdo:SyncRenderOptions()
            updateDropPos()
            DropWindow.Visible = true
            if dropConn then dropConn:Disconnect() end
            dropConn = RunService.RenderStepped:Connect(updateDropPos)
            TweenService:Create(Arrow, Library.TweenInfo, { Rotation = 180 }):Play()
        else
            closeMenu()
        end
    end)

    UserInputService.InputBegan:Connect(function(inp)
        if not MenuActive then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1 and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        local mx, my = inp.Position.X, inp.Position.Y
        local dp, ds = DropWindow.AbsolutePosition, DropWindow.AbsoluteSize
        local bp, bs = Disp.AbsolutePosition, Disp.AbsoluteSize
        local inDrop = mx >= dp.X and mx <= dp.X + ds.X and my >= dp.Y and my <= dp.Y + ds.Y
        local inDisp = mx >= bp.X and mx <= bp.X + bs.X and my >= bp.Y and my <= bp.Y + bs.Y
        if not inDrop and not inDisp then closeMenu() end
    end)

    Dropdo:SyncRenderOptions()
    Dropdo:UpdateLabels()
    self:Resize()
    table.insert(self.Elements, Dropdo)
    if Idx then Library.Options[Idx] = Dropdo end
    return Dropdo
end

