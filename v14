local function getUIContext()
    local success, gui = pcall(function() return gethui() end)
    if success and gui then return gui end
    success, gui = pcall(function() return game:GetService("CoreGui") end)
    if success and gui then return gui end
    return game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
end

local function cleanOldUI()
    local parents = {pcall(gethui) and gethui(), game:GetService("CoreGui"), game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")}
    for _, parent in ipairs(parents) do
        if parent and typeof(parent) == "Instance" and parent:FindFirstChild("SedseLoader") then
            pcall(function() parent.SedseLoader:Destroy() end)
        end
    end
end
