            Size           = UDim2.new(1, -12, 0, hasDesc and 24 or 28),
            Text           = Info.Text:lower(),
            TextSize       = 12,
            TextColor3     = "FontColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace       = "Font",
            Parent         = Holder,
        })
        if hasDesc then
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 12, 0, 24),
                Size           = UDim2.new(1, -12, 0, 16),
                Text           = Info.Description:lower(),
                TextSize       = 10,
                TextColor3     = "SecondaryColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped    = true,
                FontFace       = "Font",
                Parent         = Holder,
            })
        end

        Holder.MouseEnter:Connect(function()
            TweenService:Create(BtnStroke, Library.TweenInfo, { Color = Library.Scheme.AccentColor }):Play()
            TweenService:Create(Holder,    Library.TweenInfo, { BackgroundColor3 = Library.Scheme.DimColor }):Play()
        end)
        Holder.MouseLeave:Connect(function()
            TweenService:Create(BtnStroke, Library.TweenInfo, { Color = Library.Scheme.OutlineColor }):Play()
            TweenService:Create(Holder,    Library.TweenInfo, { BackgroundColor3 = Library.Scheme.SubColor }):Play()
        end)
        Holder.MouseButton1Click:Connect(function()
            -- brief flash
            TweenService:Create(Holder, Library.TweenInfo, { BackgroundColor3 = Library.Scheme.AccentDim }):Play()
            task.delay(0.12, function()
                TweenService:Create(Holder, Library.TweenInfo, { BackgroundColor3 = Library.Scheme.SubColor }):Play()
            end)
            Library:SafeCallback(Info.Callback)
        end)

        local BtnObj = { Type = "Button" }
        self:Resize()
        table.insert(self.Elements, BtnObj)
        if Idx then Library.Options[Idx] = BtnObj end
        return BtnObj
    end

    -- ─── Label / Info box (new) ──────────────────────────────────────────────
    function Class:AddLabel(Info)
        if type(Info) == "string" then
            Info = { Text = Info, Description = "" }
        end
        Info = Library:Validate(Info, Templates.Label)
        local hasDesc = Info.Description and Info.Description ~= ""

        local Holder = New("Frame", {
            BackgroundColor3 = "SubColor",
            Size             = UDim2.new(1, 0, 0, hasDesc and 44 or 28),
            Parent           = self.Container,
        })
        New("UICorner", { CornerRadius = UDim.new(0, 5), Parent = Holder })
        New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Holder })

        -- "i" badge on the left
        local Badge = New("Frame", {
            BackgroundColor3 = "AccentDim",
            Size             = UDim2.new(0, 28, 1, 0),
            Parent           = Holder,
        })
        New("UICorner", { CornerRadius = UDim.new(0, 5), Parent = Badge })
        -- square off the right corners of badge
        New("Frame", {
            BackgroundColor3 = "AccentDim",
            AnchorPoint      = Vector2.new(1, 0),
            Position         = UDim2.new(1, 0, 0, 0),
            Size             = UDim2.new(0, 6, 1, 0),
            BorderSizePixel  = 0,
            Parent           = Badge,
        })
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size       = UDim2.new(1, 0, 1, 0),
            Text       = "i",
            TextSize   = 13,
            TextColor3 = "AccentColor",
            FontFace   = "Font",
            Parent     = Badge,
        })

        local LabelRef = New("TextLabel", {
            BackgroundTransparency = 1,
            Position       = UDim2.new(0, 36, 0, 0),
            Size           = UDim2.new(1, -42, 0, hasDesc and 24 or 28),
            Text           = Info.Text:lower(),
            TextSize       = 11,
            TextColor3     = "FontColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped    = true,
            FontFace       = "Font",
            Parent         = Holder,
        })
        if hasDesc then
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 36, 0, 24),
                Size           = UDim2.new(1, -42, 0, 16),
                Text           = Info.Description:lower(),
                TextSize       = 9,
                TextColor3     = "SecondaryColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped    = true,
                FontFace       = "Font",
                Parent         = Holder,
            })
        end

        local LabelObj = { Type = "Label", _Ref = LabelRef }
        function LabelObj:SetText(txt) LabelRef.Text = tostring(txt):lower() end

        self:Resize()
        table.insert(self.Elements, LabelObj)
        return LabelObj
    end

    -- ─── Divider ─────────────────────────────────────────────────────────────
    function Class:AddDivider(TextDesc)
        local Holder = New("Frame", {
            BackgroundTransparency = 1,
            Size   = UDim2.new(1, 0, 0, 20),
            Parent = self.Container,
        })
        if TextDesc then
            New("Frame", {
                BackgroundColor3 = "OutlineColor",
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 0, 0.5, 0),
                Size             = UDim2.new(0.16, 0, 0, 1),
                Parent           = Holder,
            })
            New("TextLabel", {
                BackgroundTransparency = 1,
                AnchorPoint    = Vector2.new(0.5, 0.5),
                Position       = UDim2.new(0.5, 0, 0.5, 0),
                Size           = UDim2.new(0.68, 0, 1, 0),
                Text           = tostring(TextDesc):lower(),
                TextColor3     = "DimColor",
                TextSize       = 10,
                FontFace       = "Font",
                Parent         = Holder,
            })
            New("Frame", {
                BackgroundColor3 = "OutlineColor",
                AnchorPoint      = Vector2.new(1, 0.5),
                Position         = UDim2.new(1, 0, 0.5, 0),
                Size             = UDim2.new(0.16, 0, 0, 1),
                Parent           = Holder,
            })
        else
            New("Frame", {
                BackgroundColor3 = "OutlineColor",
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 0, 0.5, 0),
                Size             = UDim2.new(1, 0, 0, 1),
                Parent           = Holder,
            })
        end
        self:Resize()
    end

    ElementsClass.__index = Class
end

-- ─── GBLayout resize ─────────────────────────────────────────────────────────
local GBLayout = setmetatable({}, ElementsClass)
function GBLayout:Resize()
    local ll = self.Container:FindFirstChildOfClass("UIListLayout")
    local h  = ll and ll.AbsoluteContentSize.Y or 0
    self.Holder.Size = UDim2.new(1, 0, 0, h + 46)

    if self.TabObj and self.TabObj.MainPage then
        local L = self.TabObj.ColumnL:FindFirstChildOfClass("UIListLayout")
        local R = self.TabObj.ColumnR:FindFirstChildOfClass("UIListLayout")
        if L and R then
            self.TabObj.MainPage.CanvasSize = UDim2.new(
                0, 0, 0,
                math.max(L.AbsoluteContentSize.Y, R.AbsoluteContentSize.Y) + 30
            )
        end
    end
end
GBLayout.__index = GBLayout

-- ═══════════════════════════════════════════════════════════════════════════
--                            Window Engine
-- ═══════════════════════════════════════════════════════════════════════════

function Library:CreateWindow(Info)
    Info = Library:Validate(Info, Templates.Window)
    if typeof(Info.Font) == "EnumItem" then Library.Scheme.FontId = Info.Font end

    local SW     = Library.SidebarWidth
    local center = UDim2.new(0.5, -Info.Size.X.Offset / 2, 0.5, -Info.Size.Y.Offset / 2)

    local Window = New("Frame", {
        BackgroundColor3 = "BackgroundColor",
        Position         = Info.Position or center,
        Size             = Info.Size,
        Active           = true,
        ClipsDescendants = true,
        Parent           = ScreenGui,
    })
    New("UICorner", { CornerRadius = UDim.new(0, Library.CornerRadius), Parent = Window })
    New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Window })

    -- ── Left Sidebar ─────────────────────────────────────────────────────────
    local Sidebar = New("Frame", {
        BackgroundColor3 = "SidebarColor",
        Size             = UDim2.new(0, SW, 1, 0),
        ClipsDescendants = true,
        Parent           = Window,
    })
    New("UICorner", { CornerRadius = UDim.new(0, Library.CornerRadius), Parent = Sidebar })
    -- Patch right corners square so they don't show rounded edge inside window
    New("Frame", {
        BackgroundColor3 = "SidebarColor",
        AnchorPoint      = Vector2.new(1, 0),
        Position         = UDim2.new(1, 0, 0, 0),
        Size             = UDim2.new(0, Library.CornerRadius, 1, 0),
        BorderSizePixel  = 0,
        Parent           = Sidebar,
    })
    -- Right-edge 1px separator
    New("Frame", {
        BackgroundColor3 = "OutlineColor",
        AnchorPoint      = Vector2.new(1, 0),
        Position         = UDim2.new(1, 0, 0, 0),
        Size             = UDim2.new(0, 1, 1, 0),
        Parent           = Sidebar,
    })

    -- Logo / title area (also the drag target)
    local LogoArea = New("Frame", {
        BackgroundTransparency = 1,
        Size   = UDim2.new(1, 0, 0, 54),
        Parent = Sidebar,
    })
    -- Top accent 1px strip
    New("Frame", {
        BackgroundColor3 = "AccentColor",
        Size             = UDim2.new(1, 0, 0, 1),
        Parent           = LogoArea,
    })
    -- Bottom separator
    New("Frame", {
        BackgroundColor3 = "OutlineColor",
        AnchorPoint      = Vector2.new(0, 1),
        Position         = UDim2.new(0, 0, 1, 0),
        Size             = UDim2.new(1, 0, 0, 1),
        Parent           = LogoArea,
    })
    local Dot = New("Frame", {
        BackgroundColor3 = "AccentColor",
        AnchorPoint      = Vector2.new(0, 0.5),
        Position         = UDim2.new(0, 16, 0.5, 0),
        Size             = UDim2.fromOffset(6, 6),
        Parent           = LogoArea,
    })
    New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Dot })
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position       = UDim2.new(0, 30, 0, 0),
        Size           = UDim2.new(1, -34, 1, 0),
        Text           = Info.Title,
        TextSize       = 12,
        TextColor3     = "FontColor",
        TextXAlignment = Enum.TextXAlignment.Left,
        FontFace       = "Font",
        Parent         = LogoArea,
    })

    Library:MakeDraggable(Window, LogoArea)

    -- Scrollable tab list
    local TabList = New("ScrollingFrame", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 0, 0, 54),
        Size                   = UDim2.new(1, 0, 1, -72),
        ScrollBarThickness     = 0,
        CanvasSize             = UDim2.new(),
        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
        Parent                 = Sidebar,
    })
    New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 2),
        Parent    = TabList,
    })
    New("UIPadding", {
        PaddingTop    = UDim.new(0, 8),
        PaddingBottom = UDim.new(0, 8),
        PaddingLeft   = UDim.new(0, 8),
        PaddingRight  = UDim.new(0, 8),
        Parent        = TabList,
    })

    -- Sidebar footer (keybind hint)
    local SideFooter = New("Frame", {
        BackgroundTransparency = 1,
        AnchorPoint            = Vector2.new(0, 1),
        Position               = UDim2.new(0, 0, 1, 0),
        Size                   = UDim2.new(1, 0, 0, 18),
        Parent                 = Sidebar,
    })
    New("Frame", {
        BackgroundColor3 = "OutlineColor",
        Size             = UDim2.new(1, 0, 0, 1),
        Parent           = SideFooter,
    })
    New("TextLabel", {
        BackgroundTransparency = 1,
        AnchorPoint    = Vector2.new(0.5, 0.5),
        Position       = UDim2.new(0.5, 0, 0.55, 0),
        Size           = UDim2.new(1, -8, 0, 14),
        Text           = "[ rctrl ]",
        TextSize       = 9,
        TextColor3     = "DimColor",
        FontFace       = "Font",
        Parent         = SideFooter,
    })

    -- ── Content area (right of sidebar) ──────────────────────────────────────
    local Content = New("Frame", {
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, SW + 1, 0, 0),
        Size             = UDim2.new(1, -(SW + 1), 1, 0),
        ClipsDescendants = true,
        Parent           = Window,
    })

    -- ─────────────────────────────────────────────────────────────────────────
    local UIStateObj = { ExtTabs = {} }

    function UIStateObj:AddTab(LabelT, IconSource)

        -- Pill tab button (in sidebar)
        local TabBtn = New("TextButton", {
            BackgroundColor3     = "SubColor",
            BackgroundTransparency = 1,
            Size                 = UDim2.new(1, 0, 0, 30),
            Text                 = "",
            Parent               = TabList,
        })
        New("UICorner", { CornerRadius = UDim.new(0, 5), Parent = TabBtn })

        -- Animated active bar (left edge of button)
        local ActiveBar = New("Frame", {
            BackgroundColor3 = "AccentColor",
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(0, 0, 0.5, 0),
            Size             = UDim2.new(0, 2, 0, 0),
            Parent           = TabBtn,
        })
        New("UICorner", { CornerRadius = UDim.new(0, 2), Parent = ActiveBar })

        local InnerRow = New("Frame", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 10, 0, 0),
            Size     = UDim2.new(1, -10, 1, 0),
            Parent   = TabBtn,
        })
        New("UIListLayout", {
            FillDirection     = Enum.FillDirection.Horizontal,
            SortOrder         = Enum.SortOrder.LayoutOrder,
            Padding           = UDim.new(0, 6),
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Parent            = InnerRow,
        })

        local AcCis = Library:GetCustomIcon(IconSource or "menu")
        local IcoRef = New("ImageLabel", {
            BackgroundTransparency = 1,
            Size            = UDim2.fromOffset(12, 12),
            Image           = AcCis and AcCis.Url or "",
            ImageRectOffset = AcCis and AcCis.ImageRectOffset or Vector2.zero,
            ImageRectSize   = AcCis and AcCis.ImageRectSize   or Vector2.zero,
            ImageColor3     = "DimColor",
            LayoutOrder     = 1,
            Parent          = InnerRow,
        })
        local TitleRef = New("TextLabel", {
            BackgroundTransparency = 1,
            AutomaticSize  = Enum.AutomaticSize.X,
            Size           = UDim2.new(0, 0, 0, 14),
            Text           = LabelT:lower(),
            TextSize       = 11,
            TextColor3     = "SecondaryColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace       = "Font",
            LayoutOrder    = 2,
            Parent         = InnerRow,
        })

        -- Page (scrollable, full content area)
        local Page = New("ScrollingFrame", {
            BackgroundTransparency = 1,
            Size               = UDim2.new(1, 0, 1, 0),
            CanvasSize         = UDim2.new(),
            ScrollBarThickness = 2,
            Visible            = false,
            Parent             = Content,
        })
        New("UIPadding", {
            PaddingTop    = UDim.new(0, 14),
            PaddingBottom = UDim.new(0, 14),
            PaddingLeft   = UDim.new(0, 14),
            PaddingRight  = UDim.new(0, 14),
            Parent        = Page,
        })

        local Lx = New("Frame", {
            BackgroundTransparency = 1,
            Size   = UDim2.new(0.5, -7, 1, 0),
            Parent = Page,
        })
        local Rx = New("Frame", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(1, 0),
            Position    = UDim2.new(1, 0, 0, 0),
            Size        = UDim2.new(0.5, -7, 1, 0),
            Parent      = Page,
        })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10), Parent = Lx })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10), Parent = Rx })

        local CurCtxt = { MainPage = Page, ColumnL = Lx, ColumnR = Rx }

        local function deselect()
            IcoRef.ImageColor3  = Library.Scheme.DimColor
            TitleRef.TextColor3 = Library.Scheme.SecondaryColor
            TweenService:Create(TabBtn,    Library.TweenInfo, { BackgroundTransparency = 1 }):Play()
            TweenService:Create(ActiveBar, Library.TweenInfo, { Size = UDim2.new(0, 2, 0, 0) }):Play()
            Page.Visible = false
        end

        local function select()
            IcoRef.ImageColor3      = Library.Scheme.AccentColor
            TitleRef.TextColor3     = Library.Scheme.FontColor
            TabBtn.BackgroundColor3 = Library.Scheme.SubColor
            TweenService:Create(TabBtn,    Library.TweenInfo, { BackgroundTransparency = 0 }):Play()
            TweenService:Create(ActiveBar, Library.TweenInfo, { Size = UDim2.new(0, 2, 0, 16) }):Play()
            Page.Visible = true
        end

        TabBtn.MouseEnter:Connect(function()
            if Library.RefSysTab and Library.RefSysTab.PageInstance == Page then return end
            TweenService:Create(TabBtn, Library.TweenInfo, { BackgroundTransparency = 0.7 }):Play()
            TitleRef.TextColor3 = Library.Scheme.FontColor
        end)
        TabBtn.MouseLeave:Connect(function()
            if Library.RefSysTab and Library.RefSysTab.PageInstance == Page then return end
            TweenService:Create(TabBtn, Library.TweenInfo, { BackgroundTransparency = 1 }):Play()
            TitleRef.TextColor3 = Library.Scheme.SecondaryColor
        end)

        TabBtn.MouseButton1Click:Connect(function()
            if Library.RefSysTab then Library.RefSysTab.Deselect() end
            select()
            Library.RefSysTab = { PageInstance = Page, Deselect = deselect }
        end)

        if not Library.RefSysTab then
            select()
            Library.RefSysTab = { PageInstance = Page, Deselect = deselect }
        end

        -- ── AddGroup ─────────────────────────────────────────────────────────
        function CurCtxt:AddGroup(TitleG, AlignmentID)
            local Col  = AlignmentID == 2 and Rx or Lx
            local Grpx = New("Frame", {
                BackgroundColor3 = "MainColor",
                Size             = UDim2.new(1, 0, 0, 100),
                Parent           = Col,
            })
            New("UICorner", { CornerRadius = UDim.new(0, 5), Parent = Grpx })
            New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Grpx })

            -- Flat header: dot + label + separator
            local HeaderArea = New("Frame", {
                BackgroundTransparency = 1,
                Size   = UDim2.new(1, 0, 0, 28),
                Parent = Grpx,
            })
            local GDot = New("Frame", {
                BackgroundColor3 = "AccentColor",
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 12, 0.5, 0),
                Size             = UDim2.fromOffset(4, 4),
                Parent           = HeaderArea,
            })
            New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = GDot })
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 22, 0, 0),
                Size           = UDim2.new(1, -34, 1, 0),
                Text           = TitleG:lower(),
                TextSize       = 11,
                TextColor3     = "SecondaryColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                FontFace       = "Font",
                Parent         = HeaderArea,
            })
            New("Frame", {
                BackgroundColor3 = "OutlineColor",
                AnchorPoint      = Vector2.new(0, 1),
                Position         = UDim2.new(0, 0, 1, 0),
                Size             = UDim2.new(1, 0, 0, 1),
                Parent           = HeaderArea,
            })

            local PContainer = New("Frame", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 0, 0, 28),
                Size     = UDim2.new(1, 0, 1, -28),
                Parent   = Grpx,
            })
            New("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding   = UDim.new(0, 8),
                Parent    = PContainer,
            })
            New("UIPadding", {
                PaddingTop    = UDim.new(0, 10),
                PaddingBottom = UDim.new(0, 12),
                PaddingLeft   = UDim.new(0, 12),
                PaddingRight  = UDim.new(0, 12),
                Parent        = PContainer,
            })

            local Master = {
                Holder    = Grpx,
                Container = PContainer,
                Elements  = {},
                TabObj    = CurCtxt,
            }
            setmetatable(Master, GBLayout)
            Master:Resize()
            return Master
        end

        function CurCtxt:AddLeftGroupbox(name)  return CurCtxt:AddGroup(name, 1) end
        function CurCtxt:AddRightGroupbox(name) return CurCtxt:AddGroup(name, 2) end

        return CurCtxt
    end

    UserInputService.InputBegan:Connect(function(Imp)
        if Imp.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end)

    return UIStateObj
end

getgenv().Library = Library
return Library
