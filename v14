    function Class:AddToggle(Idx, Info)
        Info = Library:Validate(Info, Templates.Toggle)
        local hasDesc = Info.Description and Info.Description ~= ""
        local Height  = hasDesc and 44 or 28

        local Holder = New("TextButton", {
            BackgroundTransparency = 1,
            Size   = UDim2.new(1, 0, 0, Height),
            Text   = "",
            Parent = self.Container,
        })

        local Track = New("Frame", {
            BackgroundColor3 = "SubColor",
            AnchorPoint      = Vector2.new(1, hasDesc and 0 or 0.5),
            Position         = hasDesc and UDim2.new(1, 0, 0, 4) or UDim2.new(1, 0, 0.5, 0),
            Size             = UDim2.fromOffset(34, 18),
            Parent           = Holder,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })
        local TrackStroke = New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Track })

        local Thumb = New("Frame", {
            BackgroundColor3 = "DimColor",
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(0, 2, 0.5, 0),
            Size             = UDim2.fromOffset(14, 14),
            Parent           = Track,
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Thumb })

        New("TextLabel", {
            BackgroundTransparency = 1,
            Position       = UDim2.new(0, 0, 0, 0),
            Size           = UDim2.new(1, -44, 0, hasDesc and 16 or Height),
            Text           = Info.Text:lower(),
            TextSize       = 12,
            TextColor3     = "FontColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace       = "Font",
            Parent         = Holder,
        })
        if hasDesc then
            New("TextLabel", {
                BackgroundTransparency = 1,
                Position       = UDim2.new(0, 0, 0, 18),
                Size           = UDim2.new(1, -44, 0, 18),
                Text           = Info.Description:lower(),
                TextSize       = 10,
                TextColor3     = "SecondaryColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped    = true,
                FontFace       = "Font",
                Parent         = Holder,
            })
        end

        local ToggleObj = { Value = Info.Default, Type = "Toggle", Callback = Info.Callback }

        function ToggleObj:UpdateDisplay()
            local on     = ToggleObj.Value
            local accent = Library.Scheme.AccentColor
            TweenService:Create(Thumb, Library.TweenInfo, {
                Position         = on and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                BackgroundColor3 = on and accent or Library.Scheme.DimColor,
            }):Play()
            TweenService:Create(Track, Library.TweenInfo, {
                BackgroundColor3 = on and Library.Scheme.AccentDim or Library.Scheme.SubColor,
            }):Play()
            TweenService:Create(TrackStroke, Library.TweenInfo, {
                Color = on and accent or Library.Scheme.OutlineColor,
            }):Play()
        end

        function ToggleObj:SetValue(Val)
            ToggleObj.Value = Val
            ToggleObj:UpdateDisplay()
            Library:SafeCallback(ToggleObj.Callback, Val)
        end

        Holder.MouseButton1Click:Connect(function() ToggleObj:SetValue(not ToggleObj.Value) end)
        ToggleObj:UpdateDisplay()
        self:Resize()
        table.insert(self.Elements, ToggleObj)
        Library.Options[Idx] = ToggleObj
        return ToggleObj
    end

