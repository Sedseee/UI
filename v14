function GBLayout:Resize()
    local ll = self.Container:FindFirstChildOfClass("UIListLayout")
    local h  = ll and ll.AbsoluteContentSize.Y or 0
    self.Holder.Size = UDim2.new(1, 0, 0, h + 46)

    if self.TabObj and self.TabObj.MainPage then
        local L = self.TabObj.ColumnL:FindFirstChildOfClass("UIListLayout")
        local R = self.TabObj.ColumnR:FindFirstChildOfClass("UIListLayout")
        if L and R then
            self.TabObj.MainPage.CanvasSize = UDim2.new(0, 0, 0, math.max(L.AbsoluteContentSize.Y, R.AbsoluteContentSize.Y) + 30)
        end
    end
end

-- ─── Toggle ───
function GBLayout:AddToggle(Idx, Info)
    Info = Library:Validate(Info, Templates.Toggle)
    local hasDesc = Info.Description and Info.Description ~= ""
    local Height  = hasDesc and 44 or 28

    local Holder = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, Height), Text = "", Parent = self.Container })
    local Track = New("Frame", { BackgroundColor3 = "SubColor", AnchorPoint = Vector2.new(1, hasDesc and 0 or 0.5), Position = hasDesc and UDim2.new(1, 0, 0, 4) or UDim2.new(1, 0, 0.5, 0), Size = UDim2.fromOffset(34, 18), Parent = Holder })
    New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Track })
    local TrackStroke = New("UIStroke", { Color = "OutlineColor", Thickness = 1, Parent = Track })

    local Thumb = New("Frame", { BackgroundColor3 = "DimColor", AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 2, 0.5, 0), Size = UDim2.fromOffset(14, 14), Parent = Track })
    New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Thumb })

    New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, -44, 0, hasDesc and 16 or Height), Text = Info.Text:lower(), TextSize = 12, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, Font = "Font", Parent = Holder })
    
    if hasDesc then
        New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 18), Size = UDim2.new(1, -44, 0, 18), Text = Info.Description:lower(), TextSize = 10, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, Font = "Font", Parent = Holder })
    end

    local ToggleObj = { Value = Info.Default, Type = "Toggle", Callback = Info.Callback }

    function ToggleObj:UpdateDisplay()
        local on = self.Value
        local accent = Library.Scheme.AccentColor
        TweenService:Create(Thumb, Library.TweenInfo, { Position = on and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0), BackgroundColor3 = on and accent or Library.Scheme.DimColor }):Play()
        TweenService:Create(Track, Library.TweenInfo, { BackgroundColor3 = on and Library.Scheme.AccentDim or Library.Scheme.SubColor }):Play()
        TweenService:Create(TrackStroke, Library.TweenInfo, { Color = on and accent or Library.Scheme.OutlineColor }):Play()
    end

    function ToggleObj:SetValue(Val)
        self.Value = Val
        self:UpdateDisplay()
        Library:SafeCallback(self.Callback, Val)
    end
    function ToggleObj:set(val) self:SetValue(val) end

    Holder.MouseButton1Click:Connect(function() ToggleObj:SetValue(not ToggleObj.Value) end)
    ToggleObj:UpdateDisplay()
    self:Resize()
    table.insert(self.Elements, ToggleObj)
    if Idx then Library.Options[Idx] = ToggleObj end
    return ToggleObj
end

-- ─── Slider ───
function GBLayout:AddSlider(Idx, Info)
    Info = Library:Validate(Info, Templates.Slider)
    local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 42), Parent = self.Container })
    local Header = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16), Parent = Holder })
    New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(0.6, 0, 1, 0), Text = Info.Text:lower(), TextSize = 11, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, Font = "Font", Parent = Header })
    local ValLab = New("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0.4, 0, 1, 0), Text = "", TextSize = 11, TextColor3 = "AccentColor", TextXAlignment = Enum.TextXAlignment.Right, Font = "Font", Parent = Header })

    local Interact = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 0, 1, 0), Size = UDim2.new(1, 0, 0, 20), Text = "", Parent = Holder })
    local Bar = New("Frame", { BackgroundColor3 = "SubColor", AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.5, 0), Size = UDim2.new(1, 0, 0, 5), Parent = Interact })
    New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Bar })
    local Fill = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0, 0, 1, 0), Parent = Bar })
    New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Fill })
    local SlThumb = New("Frame", { BackgroundColor3 = "FontColor", AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0, 0, 0.5, 0), Size = UDim2.fromOffset(11, 11), ZIndex = 3, Parent = Bar })
    New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = SlThumb })
    New("UIStroke", { Color = "AccentColor", Thickness = 2, Parent = SlThumb })

    local SliderObj = { Value = Info.Default, Type = "Slider" }

    function SliderObj:UpdateDisplay()
        local pct = math.clamp((self.Value - Info.Min) / (Info.Max - Info.Min), 0, 1)
        ValLab.Text = tostring(self.Value) .. Info.Suffix
        TweenService:Create(Fill, Library.TweenInfo, { Size = UDim2.new(pct, 0, 1, 0) }):Play()
        TweenService:Create(SlThumb, Library.TweenInfo, { Position = UDim2.new(pct, 0, 0.5, 0) }):Play()
    end

    function SliderObj:SetValue(Val)
        Val = math.clamp(Val, Info.Min, Info.Max)
        if Info.Rounding > 0 then
            local m = 10 ^ Info.Rounding
            Val = math.floor(Val * m + 0.5) / m
        else
            Val = math.floor(Val + 0.5)
        end
        self.Value = Val
        self:UpdateDisplay()
        Library:SafeCallback(Info.Callback, Val)
    end
    function SliderObj:set(val) self:SetValue(val) end

    local SlDragging = false
    Interact.InputBegan:Connect(function(Imp)
        if Imp.UserInputType == Enum.UserInputType.MouseButton1 or Imp.UserInputType == Enum.UserInputType.Touch then
            SlDragging = true
            while SlDragging and RunService.RenderStepped:Wait() do
                local mX  = UserInputService:GetMouseLocation().X
                local bX  = Interact.AbsolutePosition.X
                local pct = math.clamp((mX - bX) / Interact.AbsoluteSize.X, 0, 1)
                SliderObj:SetValue(Info.Min + (Info.Max - Info.Min) * pct)
            end
        end
    end)
    UserInputService.InputEnded:Connect(function(Imp)
        if Imp.UserInputType == Enum.UserInputType.MouseButton1 or Imp.UserInputType == Enum.UserInputType.Touch then
            SlDragging = false
        end
    end)

    SliderObj:UpdateDisplay()
    self:Resize()
    table.insert(self.Elements, SliderObj)
    if Idx then Library.Options[Idx] = SliderObj end
    return SliderObj
end

