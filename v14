-- ─── Draggable ───────────────────────────────────────────────────────────────
function Library:MakeDraggable(UI, DraggerTarget)
    local Dragging, DragInput, StartPos, StartBounds
    DraggerTarget.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true; StartPos = input.Position; StartBounds = UI.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then Dragging = false end
            end)
        end
    end)
    DraggerTarget.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then DragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == DragInput and Dragging then
            local Delta = input.Position - StartPos
            UI.Position = UDim2.new(StartBounds.X.Scale, StartBounds.X.Offset + Delta.X, StartBounds.Y.Scale, StartBounds.Y.Offset + Delta.Y)
        end
    end)
end

