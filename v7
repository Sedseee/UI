        local MenuList = New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,2), Parent = DropdownMenu })
        
        local MenuOpen = false
        function Dropdown:Display()
            local str = ""
            if Info.Multi then
                local sel = {}
                for k,v in pairs(Dropdown.Value) do if v then table.insert(sel, k) end end
                str = #sel > 0 and table.concat(sel, ", ") or "off"
            else
                str = Dropdown.Value or "off"
            end
            Disp.Text = str
        end

        function Dropdown:Build()
            for _, child in pairs(DropdownMenu:GetChildren()) do
                if child:IsA("TextButton") then child:Destroy() end
            end

            local YSize = 2
            for i, val in ipairs(Dropdown.Values) do
                local Btn = New("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 24), Text = tostring(val), TextSize = 12, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", ZIndex = 11, Parent = DropdownMenu })
                New("UIPadding", { PaddingLeft = UDim.new(0, 8), Parent = Btn })
                
                Btn.MouseButton1Click:Connect(function()
                    if Info.Multi then
                        if Dropdown.Value[val] then
                            Dropdown.Value[val] = nil
                        else
                            Dropdown.Value[val] = true
                        end
                    else
                        Dropdown.Value = val
                        MenuOpen = false
                        DropdownMenu.Visible = false
                    end
                    Dropdown:Display()
                    Library:SafeCallback(Dropdown.Callback, Dropdown.Value)
                end)
                YSize = YSize + 26
            end
            
            local ActualSizeY = math.clamp(YSize, 0, 150)
            DropdownMenu.Size = UDim2.new(1, 2, 0, ActualSizeY)
            DropdownMenu.CanvasSize = UDim2.new(0, 0, 0, YSize)
        end

        Disp.MouseButton1Click:Connect(function()
            MenuOpen = not MenuOpen
            DropdownMenu.Visible = MenuOpen
        end)

        Dropdown:Build(); Dropdown:Display(); Groupbox:Resize()
        table.insert(Groupbox.Elements, Dropdown); Library.Options[Idx] = Dropdown
        return Dropdown
    end

