        -- The Drop menu background handles clipping
        local DropdownMenu = New("ScrollingFrame", { BackgroundColor3 = "MainColor", Position = UDim2.new(0, -1, 1, 4), Size = UDim2.new(1, 2, 0, 0), Visible = false, ScrollBarThickness = 2, ZIndex = 10, Parent = Disp })
        New("UICorner", { CornerRadius = UDim.new(0, 4), Parent = DropdownMenu })
