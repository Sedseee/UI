local BaseGroupbox = {}
do
    local Funcs = setmetatable({}, BaseAddons)
    function Funcs:Resize()
        local height = 0
        for _, child in ipairs(self.Container:GetChildren()) do
            if child:IsA("GuiObject") and child.Visible then height = height + child.AbsoluteSize.Y + 6 end
        end
        self.Holder.Size = UDim2.new(1, 0, 0, height + 40)
        
        if self.Tab and self.Tab.Page then
            local max_height = math.max(self.Tab.LeftCol.UIListLayout.AbsoluteContentSize.Y, self.Tab.RightCol.UIListLayout.AbsoluteContentSize.Y)
            self.Tab.Page.CanvasSize = UDim2.new(0, 0, 0, max_height + 40)
        end
    end
    BaseGroupbox.__index = Funcs
end

