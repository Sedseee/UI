    function Funcs:AddSlider(Idx, Info)
        Info = Library:Validate(Info, Templates.Slider)
        local Groupbox = self
        local Slider = { Value = Info.Default, Min = Info.Min, Max = Info.Max, Type = "Slider", Callback = Info.Callback }

        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 36), Parent = Groupbox.Container })
        local Label = New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(0.5, 0, 0, 16), Text = Info.Text:lower(), TextSize = 12, TextColor3 = "FontColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = Holder })
        local ValLabel = New("TextLabel", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(1,0), Position = UDim2.new(1, 0, 0, 0), Size = UDim2.new(0.5, 0, 0, 16), Text = "", TextSize = 12, TextColor3 = "AccentColor", TextXAlignment = Enum.TextXAlignment.Right, FontFace = "Font", Parent = Holder })
        
        local BarArea = New("TextButton", { BackgroundTransparency = 1, AnchorPoint = Vector2.new(0,1), Position = UDim2.new(1,0,1,0), Size = UDim2.new(1, 0, 0, 14), Text = "", Parent = Holder })
        local Bar = New("Frame", { BackgroundColor3 = "MainColor", AnchorPoint = Vector2.new(0,0.5), Position = UDim2.new(0,0,0.5,0), Size = UDim2.new(1,0,0,3), Parent = BarArea })
        New("UICorner", { CornerRadius = UDim.new(1,0), Parent = Bar })
        New("UIStroke", { Color = "OutlineColor", Parent = Bar })

        local Fill = New("Frame", { BackgroundColor3 = "AccentColor", Size = UDim2.new(0,0,1,0), Parent = Bar })
        New("UICorner", { CornerRadius = UDim.new(1,0), Parent = Fill })
        local Knob = New("Frame", { BackgroundColor3 = "AccentColor", AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(1,0,0.5,0), Size = UDim2.fromOffset(10,10), Parent = Fill })
        New("UICorner", { CornerRadius = UDim.new(1,0), Parent = Knob })

        function Slider:Display()
            local Pct = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
            ValLabel.Text = tostring(Slider.Value) .. Info.Suffix
            Fill.Size = UDim2.new(math.clamp(Pct, 0, 1), 0, 1, 0)
        end

        function Slider:SetValue(Val)
            Val = math.clamp(Val, Slider.Min, Slider.Max)
            Val = Info.Rounding > 0 and (math.floor(Val * (10^Info.Rounding) + 0.5) / (10^Info.Rounding)) or math.floor(Val + 0.5)
            if Slider.Value ~= Val then
                Slider.Value = Val
                Slider:Display()
                Library:SafeCallback(Slider.Callback, Slider.Value)
            end
        end

        local Dragging = false
        BarArea.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                while Dragging and RunService.RenderStepped:Wait() do
                    -- Fix for mobile sliders: using GetMouseLocation properly tracks Touch dragging bounds globally
                    local PosX = UserInputService:GetMouseLocation().X
                    local Pct = math.clamp((PosX - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                    Slider:SetValue(Slider.Min + ((Slider.Max - Slider.Min) * Pct))
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then Dragging = false end
        end)

        Slider:Display(); Groupbox:Resize()
        table.insert(Groupbox.Elements, Slider); Library.Options[Idx] = Slider
        return Slider
    end

