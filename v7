            end
            
            Indicator.Visible = true
            TabPage.Visible = true
            TweenService:Create(TabIcon, Library.TweenInfo, { ImageColor3 = Library.Scheme.AccentColor }):Play()
            TweenService:Create(TabLabel, Library.TweenInfo, { TextColor3 = Library.Scheme.FontColor }):Play()
            Library.ActiveTab = { Indicator = Indicator, Page = TabPage, Icon = TabIcon, Label = TabLabel }
        end)
        
        if not Library.ActiveTab then
            Indicator.Visible = true; TabPage.Visible = true
            TabIcon.ImageColor3 = Library.Scheme.AccentColor; TabLabel.TextColor3 = Library.Scheme.FontColor
            Library.ActiveTab = { Indicator = Indicator, Page = TabPage, Icon = TabIcon, Label = TabLabel }
        end
        
        function TabData:AddGroupbox(Info)
            local ParentCol = (Info.Side or 1) == 1 and LeftCol or RightCol
            local GbHolder = New("Frame", { BackgroundColor3 = "MainColor", Size = UDim2.new(1, 0, 0, 100), Parent = ParentCol })
            New("UICorner", { CornerRadius = UDim.new(0, 6), Parent = GbHolder })
            New("UIStroke", { Color = "OutlineColor", Parent = GbHolder })
            
            local TopLabel = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 36), Parent = GbHolder })
            local StatusSq = New("Frame", { BackgroundColor3 = "AccentColor", Position = UDim2.fromOffset(13, 16), Size = UDim2.fromOffset(5, 5), Parent = TopLabel })
            New("UICorner", { CornerRadius = UDim.new(0, 1), Parent = StatusSq })

            New("TextLabel", { BackgroundTransparency = 1, Position = UDim2.fromOffset(28, 0), Size = UDim2.new(1, -28, 1, 0), Text = Info.Name:lower(), TextSize = 12, TextColor3 = "SecondaryColor", TextXAlignment = Enum.TextXAlignment.Left, FontFace = "Font", Parent = TopLabel })
            New("Frame", { BackgroundColor3 = "OutlineColor", Position = UDim2.new(0, 14, 1, -1), Size = UDim2.new(1, -28, 0, 1), Parent = TopLabel })
            
            local GbContainer = New("Frame", { BackgroundTransparency = 1, Position = UDim2.fromOffset(0, 36), Size = UDim2.new(1, 0, 1, -36), Parent = GbHolder })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6), Parent = GbContainer })
            New("UIPadding", { PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15), Parent = GbContainer })
            
            local Groupbox = { Holder = GbHolder, Container = GbContainer, Elements = {}, Tab = TabData }
            setmetatable(Groupbox, BaseGroupbox)
            Groupbox:Resize()
            return Groupbox
        end
        
        function TabData:AddLeftGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 1 }) end
        function TabData:AddRightGroupbox(Name) return TabData:AddGroupbox({ Name = Name, Side = 2 }) end
        return TabData
    end

    UserInputService.InputBegan:Connect(function(Input)
        if Input.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end)
    return Window
end

getgenv().Library = Library
return Library 
