        function section_api:Label(p)
            local l = library:create("TextLabel", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, 16), BackgroundTransparency = 1, Text = p.name or p.Name or "Label", TextColor3 = Theme.MutedText, FontFace = library.font, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, AutomaticSize = Enum.AutomaticSize.Y })
            return { instance = l, set = function(txt) l.Text = txt end }
        end

        function section_api:SubLabel(p)
            local l = library:create("TextLabel", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, 20), BackgroundTransparency = 1, Text = string.upper(p.name or p.Name or "LABEL"), TextColor3 = Theme.MutedText, FontFace = library.bold_font, TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left })
            return { instance = l, set = function(txt) l.Text = string.upper(txt) end }
        end

        function section_api:Button(p)
            local b = library:create("TextButton", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, 32), BackgroundColor3 = Theme.MainBG, Text = p.name or p.Name or "Button", TextColor3 = Theme.Text, FontFace = library.font, TextSize = 12, AutoButtonColor = false })
            library:create("UICorner", {Parent = b, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = b, Color = Theme.Outline, Thickness = 1})
            b.MouseButton1Click:Connect(function() library:tween(b, {BackgroundColor3 = Theme.HoverBG}, 0.1); task.wait(0.1); library:tween(b, {BackgroundColor3 = Theme.MainBG}, 0.1); if p.Callback then p.Callback() end end)
            return {}
        end

        function section_api:Toggle(p)
            local tog = { enabled = p.default or false }
            local height = p.desc and 38 or 24
            local holder = library:create("Frame", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, height), BackgroundTransparency = 1 })
            
            CreateTitleAndDesc(holder, p.name or p.Name, p.desc or p.Desc)
            
            local btn = library:create("TextButton", { Parent = holder, Size = dim2(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 2 })
            local bg = library:create("Frame", { Parent = holder, Size = dim2(0, 32, 0, 16), Position = dim2(1, -32, 0.5, -8), BackgroundColor3 = tog.enabled and Theme.Accent or Theme.MainBG })
            library:create("UICorner", {Parent = bg, CornerRadius = dim(1, 0)}); library:create("UIStroke", {Parent = bg, Color = Theme.Outline, Thickness = 1})
            
            local circ = library:create("Frame", { Parent = bg, Size = dim2(0, 12, 0, 12), Position = dim2(tog.enabled and 1 or 0, tog.enabled and -14 or 2, 0.5, -6), BackgroundColor3 = rgb(255, 255, 255), BorderSizePixel = 0 })
            library:create("UICorner", {Parent = circ, CornerRadius = dim(1, 0)})

            local function Update()
                library:tween(bg, {BackgroundColor3 = tog.enabled and Theme.Accent or Theme.MainBG}, 0.2)
                library:tween(circ, {Position = dim2(tog.enabled and 1 or 0, tog.enabled and -14 or 2, 0.5, -6)}, 0.2)
                if p.Callback then p.Callback(tog.enabled) end
            end

            btn.MouseButton1Click:Connect(function() tog.enabled = not tog.enabled; Update() end)
            
            function tog:set(state) tog.enabled = state; Update() end
            win._elementRegistry[p.name or p.Name or "Toggle"] = tog
            table.insert(win._toggleRegistry, { name = p.name or p.Name or "Toggle", api = tog })
            if win.RefreshMobileList then win:RefreshMobileList() end
            return tog
        end

        function section_api:Slider(p)
            local min, max, default = p.min or 0, p.max or 100, p.default or p.min or 0
            local decimals = p.decimals or 0 
            local formatStr = "%."..decimals.."f" .. (p.suffix and " " .. p.suffix or "")
            
            local height = (p.desc and 45 or 35)
            local s = library:create("Frame", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, height), BackgroundTransparency = 1 })
            
            CreateTitleAndDesc(s, p.name or p.Name, p.desc or p.Desc)
            
            local val_lbl = library:create("TextLabel", { Parent = s, Text = string.format(formatStr, default), Size = dim2(0, 100, 0, 14), Position = dim2(1, -100, 0, 0), BackgroundTransparency = 1, TextColor3 = Theme.Accent, TextXAlignment = Enum.TextXAlignment.Right, FontFace = library.font, TextSize = 11 })
            
            local bar_bg = library:create("Frame", { Parent = s, Size = dim2(1, 0, 0, 4), Position = dim2(0, 0, 1, -4), BackgroundColor3 = Theme.Outline, BorderSizePixel = 0 })
            library:create("UICorner", {Parent = bar_bg, CornerRadius = dim(1, 0)})
            
            local fill = library:create("Frame", { Parent = bar_bg, Size = dim2((default - min)/(max - min), 0, 1, 0), BackgroundColor3 = Theme.Accent, BorderSizePixel = 0 })
            library:create("UICorner", {Parent = fill, CornerRadius = dim(1, 0)})
            
            local thumb = library:create("Frame", { Parent = fill, Size = dim2(0, 10, 0, 10), Position = dim2(1, -5, 0.5, -5), BackgroundColor3 = Theme.Accent, BorderSizePixel = 0 })
            library:create("UICorner", {Parent = thumb, CornerRadius = dim(1, 0)})
            
            local dragging = false
            
            local function update_slider(input_x)
                local pct = math.clamp((input_x - bar_bg.AbsolutePosition.X) / bar_bg.AbsoluteSize.X, 0, 1)
                local value = min + ((max - min) * pct) 
                fill.Size = dim2(pct, 0, 1, 0)
                val_lbl.Text = string.format(formatStr, value)
                if p.Callback then p.Callback(value) end
            end

            local grabBtn = library:create("TextButton", {Parent = s, Size = dim2(1, 0, 0, 16), Position = dim2(0, 0, 1, -10), BackgroundTransparency = 1, Text = "", ZIndex = 2})
            grabBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true; update_slider(i.Position.X) end end)
            track_connection(uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end))
            track_connection(uis.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update_slider(i.Position.X) end end))

            local api = {
                set = function(self, val)
                    val = math.clamp(val, min, max)
                    fill.Size = dim2((val - min) / (max - min), 0, 1, 0)
                    val_lbl.Text = string.format(formatStr, val)
                    if p.Callback then p.Callback(val) end
                end
            }
            win._elementRegistry[p.name or p.Name or "Slider"] = api
            return api
        end

        function section_api:Dropdown(p)
            local isMulti = p.multi or p.Multi
            local selected = isMulti and (p.default or {}) or (p.default or (p.items and p.items[1]) or "None")
            local open = false
            
            local holder = library:create("Frame", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y })
            library:create("UIListLayout", {Parent = holder, Padding = dim(0, 6), SortOrder = Enum.SortOrder.LayoutOrder})
            
            local topArea = library:create("Frame", { Parent = holder, Size = dim2(1, 0, 0, p.desc and 30 or 16), BackgroundTransparency = 1 })
            CreateTitleAndDesc(topArea, p.Name or p.name, p.desc or p.Desc)
            
            local function get_val_str() return isMulti and (#selected > 0 and table.concat(selected, ", ") or "None") or selected end
            
            local btn = library:create("TextButton", { Parent = holder, Size = dim2(1, 0, 0, 26), BackgroundColor3 = Theme.MainBG, Text = "  " .. get_val_str(), TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, FontFace = library.font, TextSize = 11, AutoButtonColor=false })
            library:create("UICorner", {Parent = btn, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = btn, Color = Theme.Outline, Thickness = 1})
            
            local icon = get_icon("lucide:chevron-down", Theme.MutedText)
            if icon then icon.Size = dim2(0, 14, 0, 14); icon.Position = dim2(1, -20, 0.5, 0); icon.AnchorPoint = Vector2.new(0, 0.5); icon.Parent = btn end
            
            local container = library:create("Frame", { Parent = holder, Size = dim2(1, 0, 0, 0), BackgroundTransparency = 1, Visible = false, AutomaticSize = Enum.AutomaticSize.Y })
            library:create("UIListLayout", {Parent = container, Padding = dim(0, 4), SortOrder = Enum.SortOrder.LayoutOrder})
            
            local itemBtns = {}
            
            local function updateItems()
                for _, iBtn in pairs(itemBtns) do
                    local isSel = isMulti and table.find(selected, iBtn.name) or (selected == iBtn.name)
                    iBtn.btn.BackgroundColor3 = isSel and Theme.HoverBG or Theme.MainBG
                    iBtn.btn.TextColor3 = isSel and Theme.Accent or Theme.MutedText
                end
                btn.Text = "  " .. get_val_str()
            end
            
            btn.MouseButton1Click:Connect(function() 
                open = not open; container.Visible = open 
                if icon then
                    icon:Destroy()
                    icon = get_icon(open and "lucide:chevron-up" or "lucide:chevron-down", Theme.MutedText)
                    icon.Size = dim2(0, 14, 0, 14); icon.Position = dim2(1, -20, 0.5, 0); icon.AnchorPoint = Vector2.new(0, 0.5); icon.Parent = btn
                end
            end)
            
            local function build_items(itemList)
                for _, iBtn in pairs(itemBtns) do iBtn.btn:Destroy() end
                itemBtns = {}
                if not isMulti and not table.find(itemList, selected) then 
                    selected = itemList[1] or "None"; if p.Callback then p.Callback(selected) end
                end
                for index, item in pairs(itemList or {}) do
                    local ibtn = library:create("TextButton", { Parent = container, LayoutOrder = index, Size = dim2(1, 0, 0, 24), BackgroundColor3 = Theme.MainBG, Text = "  " .. item, TextColor3 = Theme.MutedText, TextXAlignment = Enum.TextXAlignment.Left, FontFace = library.font, TextSize = 11, AutoButtonColor = false })
                    library:create("UICorner", {Parent = ibtn, CornerRadius = dim(0, 4)}); table.insert(itemBtns, {btn = ibtn, name = item})
                    ibtn.MouseButton1Click:Connect(function()
                        if isMulti then 
                            local idx = table.find(selected, item); if idx then table.remove(selected, idx) else table.insert(selected, item) end 
                        else 
                            selected = item; open = false; container.Visible = false 
                            if icon then
                                icon:Destroy(); icon = get_icon("lucide:chevron-down", Theme.MutedText)
                                icon.Size = dim2(0, 14, 0, 14); icon.Position = dim2(1, -20, 0.5, 0); icon.AnchorPoint = Vector2.new(0, 0.5); icon.Parent = btn
                            end
                        end
                        updateItems(); if p.Callback then p.Callback(selected) end
                    end)
                end
                updateItems()
            end

            build_items(p.items or {})
            
            local api = {
                set_items = function(self, new_items) build_items(new_items) end,
                set_value = function(self, val) selected = val; updateItems(); if p.Callback then p.Callback(selected) end end,
                set = function(self, val) self:set_value(val) end,
                get_value = function(self) return selected end
            }
            win._elementRegistry[p.Name or p.name or "Dropdown"] = api
            return api
        end

        function section_api:Textbox(p)
            local holder = library:create("Frame", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y })
            library:create("UIListLayout", {Parent = holder, Padding = dim(0, 6), SortOrder = Enum.SortOrder.LayoutOrder})
            local topArea = library:create("Frame", { Parent = holder, Size = dim2(1, 0, 0, p.desc and 30 or 16), BackgroundTransparency = 1 })
            CreateTitleAndDesc(topArea, p.Name or p.name, p.desc or p.Desc)
            
            local bg = library:create("Frame", { Parent = holder, Size = dim2(1, 0, 0, 26), BackgroundColor3 = Theme.MainBG })
            library:create("UICorner", {Parent = bg, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = bg, Color = Theme.Outline, Thickness = 1})
            local box = library:create("TextBox", { Parent = bg, Size = dim2(1, -16, 1, 0), Position = dim2(0, 8, 0, 0), BackgroundTransparency = 1, Text = "", PlaceholderText = p.placeholder or p.Placeholder or "...", TextColor3 = Theme.Text, PlaceholderColor3 = Theme.MutedText, FontFace = library.font, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left })
            box.FocusLost:Connect(function() if p.Callback then p.Callback(box.Text) end end)
            
            local api = { set = function(self, text) box.Text = tostring(text); if p.Callback then p.Callback(box.Text) end end }
            win._elementRegistry[p.name or p.Name or "Textbox"] = api
            return api
        end

        function section_api:Keybind(p)
            local key = p.default or Enum.KeyCode.Unknown
            local height = p.desc and 38 or 24
            local holder = library:create("Frame", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, height), BackgroundTransparency = 1 })
            CreateTitleAndDesc(holder, p.name or p.Name, p.desc or p.Desc)
            
            local btn = library:create("TextButton", { Parent = holder, Size = dim2(0, 40, 0, 20), Position = dim2(1, -40, 0.5, -10), BackgroundColor3 = Theme.MainBG, Text = key.Name, TextColor3 = Theme.Accent, FontFace = library.font, TextSize = 11, AutoButtonColor=false })
            library:create("UICorner", {Parent = btn, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = btn, Color = Theme.Outline, Thickness = 1})
            
            local picking = false
            btn.MouseButton1Click:Connect(function() picking = true; btn.Text = "..." end)
            track_connection(uis.InputBegan:Connect(function(input, gpe)
                if picking and input.UserInputType == Enum.UserInputType.Keyboard then
                    picking = false; key = input.KeyCode; btn.Text = key.Name
                    if p.Callback then p.Callback(key) end
                end
            end))
            
            local api = { set = function(self, new_key) key = typeof(new_key) == "string" and Enum.KeyCode[new_key] or new_key; btn.Text = key.Name; if p.Callback then p.Callback(key) end end }
            win._elementRegistry[p.Name or p.name or "Keybind"] = api
            return api
        end
        
        function section_api:Colorpicker(p)
            local open = false; local color = p.default or rgb(255, 0, 0); local h, s, v = color:ToHSV()
            local height = p.desc and 38 or 24
            local holder = library:create("Frame", { Parent = p.Parent or self.elements, Size = dim2(1, 0, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y })
            library:create("UIListLayout", {Parent = holder, Padding = dim(0, 6)})
            
            local topArea = library:create("Frame", { Parent = holder, Size = dim2(1, 0, 0, height), BackgroundTransparency = 1 })
            CreateTitleAndDesc(topArea, p.name or p.Name, p.desc or p.Desc)
            
            local dispBtn = library:create("TextButton", { Parent = topArea, Size = dim2(0, 32, 0, 16), Position = dim2(1, -32, 0.5, -8), BackgroundColor3 = color, Text = "", AutoButtonColor=false })
            library:create("UICorner", {Parent = dispBtn, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = dispBtn, Color = Theme.Outline, Thickness = 1})
            
            local container = library:create("Frame", { Parent = holder, Size = dim2(1, 0, 0, 130), BackgroundTransparency = 1, Visible = false })
            local wheelBg = library:create("Frame", {Parent = container, Size = dim2(1, 0, 1, 0), BackgroundColor3 = Theme.MainBG})
            library:create("UICorner", {Parent = wheelBg, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = wheelBg, Color = Theme.Outline, Thickness = 1})
            local wheel = library:create("ImageButton", { Parent = wheelBg, Size = dim2(0, 100, 0, 100), Position = dim2(0, 10, 0, 10), BackgroundTransparency = 1, Image = "rbxassetid://6020299385" })
            local pickerDot = library:create("ImageLabel", { Parent = wheel, Size = dim2(0, 12, 0, 12), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, Image = "rbxassetid://3678860011" })
            local valSlider = library:create("TextButton", { Parent = wheelBg, Size = dim2(0, 15, 0, 100), Position = dim2(0, 120, 0, 10), BackgroundColor3 = rgb(255, 255, 255), Text = "", AutoButtonColor = false })
            library:create("UICorner", {Parent = valSlider, CornerRadius = dim(0, 4)})
            local valGrad = library:create("UIGradient", { Parent = valSlider, Rotation = 90, Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromHSV(h,s,1)), ColorSequenceKeypoint.new(1, rgb(0,0,0))} })
            local valIndicator = library:create("Frame", { Parent = valSlider, Size = dim2(1, 4, 0, 4), Position = dim2(0.5, 0, 1-v, 0), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundColor3 = Theme.Text, BorderSizePixel = 0 })

            dispBtn.MouseButton1Click:Connect(function() open = not open; container.Visible = open end)
            local function update_color()
                local finalColor = Color3.fromHSV(h, s, v); dispBtn.BackgroundColor3 = finalColor
                valGrad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromHSV(h,s,1)), ColorSequenceKeypoint.new(1, rgb(0,0,0))}
                if p.Callback then p.Callback(finalColor) end
            end

            local angle = (h * math.pi * 2) - (math.pi / 2)
            pickerDot.Position = dim2(0.5 + math.cos(angle) * 0.5 * s, 0, 0.5 + math.sin(angle) * 0.5 * s, 0)

            local draggingWheel, draggingVal = false, false
            local inset = gui_service:GetGuiInset()
            wheel.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingWheel = true end end)
            valSlider.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingVal = true end end)
            track_connection(uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingWheel = false; draggingVal = false end end))
            track_connection(uis.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    local mLoc = uis:GetMouseLocation()
                    local correctedMouse = Vector2.new(mLoc.X, mLoc.Y - inset.Y)
                    if draggingWheel then
                        local wheelCenter = wheel.AbsolutePosition + (wheel.AbsoluteSize / 2)
                        local offset = correctedMouse - wheelCenter
                        local rad = wheel.AbsoluteSize.X / 2
                        if offset.Magnitude > rad then offset = offset.Unit * rad end
                        pickerDot.Position = dim2(0.5 + (offset.X / wheel.AbsoluteSize.X), 0, 0.5 + (offset.Y / wheel.AbsoluteSize.Y), 0)
                        local a = math.atan2(-offset.Y, offset.X); h = (a / (math.pi * 2)) + 0.5; h = h % 1; s = offset.Magnitude / rad; update_color()
                    elseif draggingVal then
                        local relativeY = correctedMouse.Y - valSlider.AbsolutePosition.Y
                        local clampedY = math.clamp(relativeY, 0, valSlider.AbsoluteSize.Y)
                        valIndicator.Position = dim2(0.5, 0, 0, clampedY); v = 1 - (clampedY / valSlider.AbsoluteSize.Y); update_color()
                    end
                end
            end))
            local api = { set = function(self, nc) h, s, v = nc:ToHSV(); update_color(); local a = (h * math.pi * 2) - (math.pi / 2); pickerDot.Position = dim2(0.5 + math.cos(a) * 0.5 * s, 0, 0.5 + math.sin(a) * 0.5 * s, 0); local hY = valSlider.AbsoluteSize.Y > 0 and valSlider.AbsoluteSize.Y or 100; valIndicator.Position = dim2(0.5, 0, 0, (1-v) * hY) end }
            win._elementRegistry[p.Name or p.name or "Colorpicker"] = api
            return api
        end

        function tab:Section(props)
            local s = {}
            local parent_col = (string.lower(props.side or "left") == "right") and right_col or left_col
            s.elements = library:create("Frame", { Parent = parent_col, Size = dim2(1, 0, 0, 0), BackgroundColor3 = Theme.SectionBG, AutomaticSize = Enum.AutomaticSize.Y })
            library:create("UICorner", {Parent = s.elements, CornerRadius = dim(0, 4)}); library:create("UIStroke", {Parent = s.elements, Color = Theme.Outline, Thickness = 1})
            library:create("UIListLayout", {Parent = s.elements, Padding = dim(0, 10)}); library:create("UIPadding", {Parent = s.elements, PaddingTop = dim(0, 15), PaddingBottom = dim(0, 15), PaddingLeft = dim(0, 15), PaddingRight = dim(0, 15)})
            
            local header = library:create("Frame", { Parent = s.elements, Size = dim2(1, 0, 0, 16), BackgroundTransparency = 1 })
            library:create("Frame", { Parent = header, Size = dim2(0, 6, 0, 6), Position = dim2(0, 0, 0.5, -3), BackgroundColor3 = Theme.Accent, BorderSizePixel = 0 })
            library:create("TextLabel", { Parent = header, Size = dim2(1, -12, 1, 0), Position = dim2(0, 12, 0, 0), BackgroundTransparency = 1, Text = string.lower(props.name or props.Name or "Section"), TextColor3 = Theme.MutedText, FontFace = library.font, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
            
            setmetatable(s, { __index = section_api })
            return s
        end

        return tab
    end

    -- Embedded Settings & Mobile UI (adapted to new styling)
    do
        local st = win:Tab({ name = "Settings", icon = "lucide:settings", _layoutOrder = 999999, _noAutoSelect = true })
        local controlSection = st:Section({ name = "Controls", side = "left" })
        controlSection:Keybind({ name = "Toggle Menu", default = Enum.KeyCode.RightControl, Callback = function(key) toggleKey = key end })

        local mobileSection = st:Section({ name = "Mobile Settings", side = "right" })
        local activeFloatingBtns = {}

        local function createFloatingButton(toggleName, toggleApi)
            local floatGui = library:create("ScreenGui", { Parent = ui_parent, Name = "SynqBtn_" .. toggleName, ResetOnSpawn = false })
            local floatBtn = library:create("TextButton", {
                Parent = floatGui, Size = dim2(0, 50, 0, 50), Position = dim2(0, 20, 0.5, -25 + (#activeFloatingBtns * 55)),
                BackgroundColor3 = toggleApi.enabled and Theme.Accent or Theme.SectionBG, Text = "", AutoButtonColor = false
            })
            library:create("UICorner", { Parent = floatBtn, CornerRadius = dim(1, 0) }); library:create("UIStroke", { Parent = floatBtn, Color = Theme.Outline, Thickness = 1 })
            local floatLabel = library:create("TextLabel", { Parent = floatBtn, Size = dim2(1, 0, 1, 0), BackgroundTransparency = 1, Text = string.sub(toggleName, 1, 3):upper(), TextColor3 = toggleApi.enabled and Theme.MainBG or Theme.Text, FontFace = library.bold_font, TextSize = 12 })

            local dragging, dragStart, startPos, hasMoved = false, nil, nil, false
            floatBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; hasMoved = false; dragStart = input.Position; startPos = floatBtn.Position end end)
            track_connection(uis.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart; if delta.Magnitude > 4 then hasMoved = true end; floatBtn.Position = dim2(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end))
            track_connection(uis.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then if dragging and not hasMoved then toggleApi:set(not toggleApi.enabled); library:tween(floatBtn, { BackgroundColor3 = toggleApi.enabled and Theme.Accent or Theme.SectionBG }, 0.15); floatLabel.TextColor3 = toggleApi.enabled and Theme.MainBG or Theme.Text end; dragging = false end end))
            return { gui = floatGui, destroy = function() floatGui:Destroy() end }
        end

        local function refreshMobileButtons(selectedNames)
            for name, entry in pairs(activeFloatingBtns) do if not table.find(selectedNames, name) then entry.destroy(); activeFloatingBtns[name] = nil end end
            for _, name in ipairs(selectedNames) do if not activeFloatingBtns[name] then for _, reg in ipairs(win._toggleRegistry) do if reg.name == name then activeFloatingBtns[name] = createFloatingButton(name, reg.api); break end end end end
        end

        local mobileDropdown = mobileSection:Dropdown({ name = "Mobile Buttons", desc = "Toggles to float", multi = true, items = {}, default = {}, Callback = function(selected) refreshMobileButtons(selected) end })
        function win:RefreshMobileList() local names = {}; for _, reg in ipairs(win._toggleRegistry) do table.insert(names, reg.name) end; mobileDropdown:set_items(names) end
    end

    return win
end

function library:create_notification(props)
    local name = props.name or props.Name or "Notification"
    local duration = props.duration or 4
    
    local notif = library:create("Frame", { Parent = notif_container, Size = dim2(1, 0, 0, 45), BackgroundColor3 = Theme.MainBG, BackgroundTransparency = 1 })
    library:create("UICorner", {Parent = notif, CornerRadius = dim(0, 4)})
    local stroke = library:create("UIStroke", {Parent = notif, Color = Theme.Outline, Thickness = 1, Transparency = 1})
    local ind = library:create("Frame", { Parent = notif, Size = dim2(0, 2, 1, -12), Position = dim2(0, 6, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), BackgroundColor3 = Theme.Accent, BackgroundTransparency = 1, BorderSizePixel = 0 })
    
    local title = library:create("TextLabel", { Parent = notif, Size = dim2(1, -20, 1, 0), Position = dim2(0, 16, 0, 0), BackgroundTransparency = 1, Text = name, TextColor3 = Theme.Text, FontFace = library.font, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextTransparency = 1 })
    
    library:tween(notif, {BackgroundTransparency = 0}, 0.3)
    library:tween(stroke, {Transparency = 0}, 0.3)
    library:tween(ind, {BackgroundTransparency = 0}, 0.3)
    library:tween(title, {TextTransparency = 0}, 0.3)
    
    task.delay(duration, function()
        local fade = library:tween(notif, {BackgroundTransparency = 1}, 0.5)
        library:tween(stroke, {Transparency = 1}, 0.5)
        library:tween(ind, {BackgroundTransparency = 1}, 0.5)
        library:tween(title, {TextTransparency = 1}, 0.5)
        fade.Completed:Connect(function() notif:Destroy() end)
    end)
end

return library
