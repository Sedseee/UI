    function Class:AddDivider(TextDesc)
        local Holder = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 22), Parent = self.Container })
        if TextDesc then
            New("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Text = "✦ " .. tostring(TextDesc) .. " ✦",
                TextColor3 = "SecondaryColor",
                TextSize = 11,
                FontFace = "Bubbly", Parent = Holder
            })
        else
            New("Frame", {
                BackgroundColor3 = "OutlineColor",
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(0.7, 0, 0, 2),
                Parent = Holder
            })
            New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Holder:FindFirstChildOfClass("Frame") })
        end
        self:Resize()
    end

    ElementsClass.__index = Class
end

local GBLayout = setmetatable({}, ElementsClass)
function GBLayout:Resize()
    local listLayout = self.Container:FindFirstChildOfClass("UIListLayout")
    local h = listLayout and listLayout.AbsoluteContentSize.Y or 0
    self.Holder.Size = UDim2.new(1, 0, 0, h + 50)

    if self.TabObj and self.TabObj.MainPage then
        local L = self.TabObj.ColumnL:FindFirstChildOfClass("UIListLayout")
        local R = self.TabObj.ColumnR:FindFirstChildOfClass("UIListLayout")
        if L and R then
            self.TabObj.MainPage.CanvasSize = UDim2.new(0, 0, 0, math.max(L.AbsoluteContentSize.Y, R.AbsoluteContentSize.Y) + 40)
        end
    end
end
GBLayout.__index = GBLayout

-- =============== Window Engine ===============
function Library:CreateWindow(Info)
    Info = Library:Validate(Info, Templates.Window)

    local center = UDim2.new(0.5, -Info.Size.X.Offset/2, 0.5, -Info.Size.Y.Offset/2)
    local Window = New("Frame", {
        BackgroundColor3 = "BackgroundColor",
        Position = Info.Position or center,
        Size = Info.Size,
        Active = true,
        ClipsDescendants = false,
        Parent = ScreenGui
    })
    New("UICorner", { CornerRadius = UDim.new(0, 20), Parent = Window })
    MakeShadow(Window, 0.5)

    -- Floating Sidebar (left card)
    local SidebarWidth = 150
    local Sidebar = New("Frame", {
        BackgroundColor3 = "SidebarColor",
        Position = UDim2.new(0, 12, 0, 12),
        Size = UDim2.new(0, SidebarWidth, 1, -24),
        Parent = Window
    })
    New("UICorner", { CornerRadius = UDim.new(0, 16), Parent = Sidebar })
    New("UIStroke", { Color = "OutlineColor", Thickness = 1, Transparency = 0.3, Parent = Sidebar })

    -- Title bubble on top of sidebar
    local TitleBubble = New("Frame", {
        BackgroundColor3 = "AccentColor",
        Position = UDim2.new(0, 14, 0, 14),
        Size = UDim2.new(1, -28, 0, 44),
        Parent = Sidebar
    })
    New("UICorner", { CornerRadius = UDim.new(0, 14), Parent = TitleBubble })

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = Info.Title,
        TextSize = 18,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        FontFace = "Bubbly", Parent = TitleBubble
    })

    Library:MakeDraggable(Window, TitleBubble)

    local TabsScroll = New("ScrollingFrame", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 70),
        Size = UDim2.new(1, -20, 1, -90),
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(),
        Parent = Sidebar
    })
    New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        Parent = TabsScroll
    })

    -- Close button (bottom of sidebar)
    local CloseBtn = New("TextButton", {
        BackgroundColor3 = "SubColor",
        AnchorPoint = Vector2.new(0.5, 1),
        Position = UDim2.new(0.5, 0, 1, -10),
        Size = UDim2.new(1, -28, 0, 28),
        Text = "✕  close",
        TextSize = 12,
        TextColor3 = "SecondaryColor",
        FontFace = "Bubbly",
        AutoButtonColor = false,
        Parent = Sidebar
    })
    New("UICorner", { CornerRadius = UDim.new(0, 12), Parent = CloseBtn })
    CloseBtn.MouseEnter:Connect(function()
        TweenService:Create(CloseBtn, Library.QuickTween, {
            BackgroundColor3 = Color3.fromRGB(255, 180, 180),
            TextColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
    end)
    CloseBtn.MouseLeave:Connect(function()
        TweenService:Create(CloseBtn, Library.QuickTween, {
            BackgroundColor3 = Library.Scheme.SubColor,
            TextColor3 = Library.Scheme.SecondaryColor
        }):Play()
    end)
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    -- Content area (right card)
    local Content = New("Frame", {
        BackgroundColor3 = "SidebarColor",
        Position = UDim2.new(0, SidebarWidth + 24, 0, 12),
        Size = UDim2.new(1, -(SidebarWidth + 36), 1, -24),
        ClipsDescendants = true,
        Parent = Window
    })
    New("UICorner", { CornerRadius = UDim.new(0, 16), Parent = Content })
    New("UIStroke", { Color = "OutlineColor", Thickness = 1, Transparency = 0.3, Parent = Content })

    local UIStateObj = { ExtTabs = {} }

    function UIStateObj:AddTab(LabelT, IconSource)
        local TabBtn = New("TextButton", {
            BackgroundColor3 = "SubColor",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 36),
            Text = "", AutoButtonColor = false,
            Parent = TabsScroll
        })
        New("UICorner", { CornerRadius = UDim.new(0, 12), Parent = TabBtn })
        New("UIPadding", {
            PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 10),
            Parent = TabBtn
        })

        -- Little accent dot
        local Dot = New("Frame", {
            BackgroundColor3 = "DimColor",
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 0, 0.5, 0),
            Size = UDim2.fromOffset(6, 6),
            Parent = TabBtn
        })
        New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = Dot })

        local TitleRef = New("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0, 0),
            Size = UDim2.new(1, -14, 1, 0),
            Text = LabelT, TextSize = 13,
            TextColor3 = "SecondaryColor",
            TextXAlignment = Enum.TextXAlignment.Left,
            FontFace = "Bubbly", Parent = TabBtn
        })

        local Page = New("ScrollingFrame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            CanvasSize = UDim2.new(),
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Library.Scheme.AccentSoft,
            Visible = false,
            Parent = Content
        })
        New("UIPadding", {
            PaddingTop = UDim.new(0, 16),
            PaddingBottom = UDim.new(0, 16),
            PaddingLeft = UDim.new(0, 16),
            PaddingRight = UDim.new(0, 16),
            Parent = Page
        })

        local Lx = New("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(0.5, -8, 1, 0),
            Parent = Page
        })
        local Rx = New("Frame", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, 0, 0, 0),
            Size = UDim2.new(0.5, -8, 1, 0),
            Parent = Page
        })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 14), Parent = Lx })
        New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 14), Parent = Rx })

        local CurCtxt = { MainPage = Page, ColumnL = Lx, ColumnR = Rx }

        local function deselect()
            TweenService:Create(TabBtn, Library.QuickTween, { BackgroundTransparency = 1 }):Play()
            TweenService:Create(TitleRef, Library.QuickTween, { TextColor3 = Library.Scheme.SecondaryColor }):Play()
            TweenService:Create(Dot, Library.QuickTween, { BackgroundColor3 = Library.Scheme.DimColor, Size = UDim2.fromOffset(6, 6) }):Play()
            Page.Visible = false
        end
        local function select()
            TweenService:Create(TabBtn, Library.QuickTween, { BackgroundTransparency = 0, BackgroundColor3 = Library.Scheme.AccentSoft }):Play()
            TweenService:Create(TitleRef, Library.QuickTween, { TextColor3 = Library.Scheme.FontColor }):Play()
            TweenService:Create(Dot, Library.TweenInfo, { BackgroundColor3 = Library.Scheme.AccentColor, Size = UDim2.fromOffset(8, 8) }):Play()
            Page.Visible = true
        end

        TabBtn.MouseEnter:Connect(function()
            if Library.RefSysTab and Library.RefSysTab.PageInstance == Page then return end
            TweenService:Create(TabBtn, Library.QuickTween, { BackgroundTransparency = 0.6 }):Play()
        end)
        TabBtn.MouseLeave:Connect(function()
            if Library.RefSysTab and Library.RefSysTab.PageInstance == Page then return end
            TweenService:Create(TabBtn, Library.QuickTween, { BackgroundTransparency = 1 }):Play()
        end)

        TabBtn.MouseButton1Click:Connect(function()
            if Library.RefSysTab then Library.RefSysTab.Deselect() end
            select()
            Library.RefSysTab = { PageInstance = Page, Deselect = deselect }
        end)

        if not Library.RefSysTab then
            select()
            Library.RefSysTab = { PageInstance = Page, Deselect = deselect }
        end

        function CurCtxt:AddGroup(TitleG, AlignmentID)
            local TrzCol = AlignmentID == 2 and Rx or Lx
            local Grpx = New("Frame", {
                BackgroundColor3 = "MainColor",
                Size = UDim2.new(1, 0, 0, 100),
                Parent = TrzCol
            })
            New("UICorner", { CornerRadius = UDim.new(0, 16), Parent = Grpx })
            New("UIStroke", { Color = "OutlineColor", Thickness = 1, Transparency = 0.4, Parent = Grpx })

            local Header = New("Frame", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 36),
                Parent = Grpx
            })
            -- Cute bubble dot
            New("Frame", {
                BackgroundColor3 = "AccentColor",
                AnchorPoint = Vector2.new(0, 0.5),
                Position = UDim2.new(0, 16, 0.5, 0),
                Size = UDim2.fromOffset(8, 8),
                Parent = Header,
            })
            local headerDot = Header:FindFirstChildOfClass("Frame")
            New("UICorner", { CornerRadius = UDim.new(1, 0), Parent = headerDot })

            New("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 32, 0, 0),
                Size = UDim2.new(1, -42, 1, 0),
                Text = TitleG, TextSize = 14,
                TextColor3 = "FontColor",
                TextXAlignment = Enum.TextXAlignment.Left,
                FontFace = "Bubbly", Parent = Header
            })

            local PContainer = New("Frame", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 0, 0, 36),
                Size = UDim2.new(1, 0, 1, -36),
                Parent = Grpx
            })
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = PContainer })
            New("UIPadding", {
                PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 12),
                PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12),
                Parent = PContainer
            })

            local Master = { Holder = Grpx, Container = PContainer, Elements = {}, TabObj = CurCtxt }
            setmetatable(Master, GBLayout)
            Master:Resize()
            return Master
        end

        function CurCtxt:AddLeftGroupbox(name)  return CurCtxt:AddGroup(name, 1) end
        function CurCtxt:AddRightGroupbox(name) return CurCtxt:AddGroup(name, 2) end

        return CurCtxt
    end

    UserInputService.InputBegan:Connect(function(Imp)
        if Imp.KeyCode == Library.ToggleKeybind and not UserInputService:GetFocusedTextBox() then
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end)
    return UIStateObj
end

getgenv().Library = Library
return Library
