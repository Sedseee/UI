            Val = math.clamp(Val, Info.Min, Info.Max)
            if Info.Rounding > 0 then
                local m = 10 ^ Info.Rounding
                Val = math.floor(Val * m + 0.5) / m
            else
                Val = math.floor(Val + 0.5)
            end
            SliderObj.Value = Val
            SliderObj:UpdateDisplay()
            Library:SafeCallback(Info.Callback, Val)
