                    if Info.Multi then
                        Dropdo.Value[TxtMap] = not Dropdo.Value[TxtMap]
                    else
                        Dropdo.Value = TxtMap
                        MenuActive = false
                        DropWindow.Visible = false
                        TweenService:Create(Arrow, Library.QuickTween, { Rotation = 0 }):Play()
                    end
                    refresh()
                    Dropdo:UpdateLabels()
                    Library:SafeCallback(Info.Callback, Dropdo.Value)
